//@version=6
// ============================================================================
// FIBONACCI AUTO-TRADING STRATEGY v2.0 (Strategy Tester)
// ============================================================================
// 
// Логика работы:
// 1. Ищет последний минимум (с проверкой тени ≤15%)
// 2. Ждет рост 100% от минимума
// 3. Строит Фибоначчи от минимума до хая (с проверкой пламени ≤15%)
// 4. При перехае (без касания уровней Этапа 1) - перестраивает Фибо выше
// 5. Этап 1: ордера $100 на 0.618, $150 на 0.5, $250 на 0.382
// 6. После SELL #1 → Этап 2: ордера сдвигаются на 0.5/0.382/0.236
// 7. После SELL #2 - Фибо завершается, ожидание нового цикла
// 8. Новый цикл = новый минимум + 100% рост → новое Фибо с нуля
// 9. SELL = "на уровень выше по цене"
//
// ============================================================================

strategy("Fibonacci Trading Strategy v2.0", 
     overlay=true, 
     max_lines_count=500, 
     max_labels_count=500, 
     max_boxes_count=500, 
     max_bars_back=500,
     initial_capital=500,
     default_qty_type=strategy.cash,
     default_qty_value=100,
     pyramiding=3,
     commission_type=strategy.commission.percent,
     commission_value=0.1,
     slippage=0,
     process_orders_on_close=true,
     calc_on_every_tick=true,
     margin_long=0,
     margin_short=0,
     fill_orders_on_standard_ohlc=true)

// ============================================================================
// НАСТРОЙКИ ИНДИКАТОРА
// ============================================================================

// Обзор стратегии
strategyInfo = input.string("", "📖 Нажмите для описания →", group="📋 Обзор стратегии",
     tooltip="СТРАТЕГИЯ FIBONACCI TRADING v2.0\n\n" +
     "═══ ЛОГИКА ВХОДА ═══\n" +
     "1. Ищем локальный MIN на графике\n" +
     "2. Ждём рост 100%+ от MIN\n" +
     "3. Строим уровни Фибоначчи\n" +
     "4. Выставляем BUY ордера:\n" +
     "   • 61.8% — $100\n" +

     "   • 50% — $150\n" +
     "   • 38.2% — $250\n\n" +
     "═══ ЛОГИКА ВЫХОДА ═══\n" +
     "После BUY ждём SELL:\n" +
     "   • 78.6% — SELL позиции 1\n" +
     "   • 61.8% — SELL позиции 2\n" +
     "   • 50% — SELL позиции 3\n\n" +
     "═══ СТОП-ЛОСС ═══\n" +
     "При касании уровня 0 (MIN)\n" +
     "все позиции закрываются\n\n" +
     "═══ НОВЫЙ ЦИКЛ ═══\n" +
     "Случай 1: Цена ниже пред. MIN\n" +
     "→ ждём 100% рост\n\n" +
     "Случай 2: Цена выше пред. MIN,\n" +
     "но MAX ниже пред. MAX\n" +
     "→ ждём 100% рост")

strategyRules = input.string("", "📌 Правила MIN/MAX →", group="📋 Обзор стратегии",
     tooltip="ПРАВИЛА ОПРЕДЕЛЕНИЯ MIN/MAX\n\n" +
     "═══ МИНИМУМ ═══\n" +
     "• Ищем самый низкий low\n" +
     "• Если тень > 15% — берём body\n" +
     "• MIN должен быть НИЖЕ\n" +
     "  предыдущего завершённого цикла\n\n" +
     "═══ МАКСИМУМ ═══\n" +
     "• Ищем high после MIN\n" +
     "• Если тень > 15% — берём body\n" +
     "• Ждём рост 100%+ от MIN\n\n" +
     "═══ ПЕРЕХАЙ ═══\n" +
     "Если после BUY цена выше MAX:\n" +
     "• До касания 0.6-0.7 — обновляем MAX\n" +
     "• После касания — блокируем\n" +
     "• После SELL — разблокируем")

lookbackPeriod = input.int(500, "Период поиска (дней)", minval=50, maxval=2000, 
     tooltip="Период для поиска минимума в днях/барах. Увеличьте если пропускаются минимумы.")
minGrowthPercent = input.float(100.0, "Мин. рост %", minval=50.0, maxval=500.0, 
     tooltip="Минимальный рост от минимума для построения Fibonacci")
wickThreshold = input.float(15.0, "Макс. тень/пламя %", minval=5.0, maxval=100.0, 
     tooltip="Максимальный размер тени/пламени свечи в %")
skipDaysAfterListing = input.int(30, "Пропустить дней после листинга", minval=0, maxval=365,
     tooltip="Количество дней/баров после начала торгов, которые будут пропущены. Помогает избежать шума в начале графика.")
useLogScale = input.bool(true, "Логарифмическая шкала Фибо",
     tooltip="Расчитывать уровни Фибоначчи по логарифмической шкале. Рекомендуется для криптовалют.")

// Настройки ордеров
orderAmount1 = input.float(100.0, "Ордер на 0.618 ($)", minval=10.0, group="Ордера")
orderAmount2 = input.float(150.0, "Ордер на 0.5 ($)", minval=10.0, group="Ордера")
orderAmount3 = input.float(250.0, "Ордер на 0.382 ($)", minval=10.0, group="Ордера")
enableStopLoss = input.bool(true, "Включить стоп-лосс", group="Ордера",
     tooltip="Закрывать позиции при касании уровня 0 (минимума). Если выключено - позиции остаются открытыми.")

// Настройки тестера стратегий
showStrategySettings = input.string("", "⚙️ Настройки тестера →", group="📊 Strategy Tester",
     tooltip="НАСТРОЙКИ STRATEGY TESTER\n\n" +
     "═══ КАПИТАЛ ═══\n" +
     "• Начальный капитал: $500\n" +
     "• Размер позиций: по сумме ордеров\n\n" +
     "═══ КОМИССИЯ ═══\n" +
     "• Тип: процент от сделки\n" +
     "• Размер: 0.1%\n\n" +
     "═══ PYRAMIDING ═══\n" +
     "• Макс. позиций: 3\n" +
     "  (для 3 уровней BUY)\n\n" +
     "═══ РЕЗУЛЬТАТЫ ═══\n" +
     "Смотрите вкладку 'Тестер стратегий'\n" +
     "внизу окна TradingView")

// Настройки отображения
showFibLines = input.bool(true, "Показывать линии Фибо", group="Отображение")
showFibLevels = input.bool(true, "Показывать уровни Фибо (%)", group="Отображение", 
     tooltip="Отображение процентов и цен на уровнях Фибоначчи")
showAllFiboHistory = input.bool(true, "Показывать все Фибо (историю)", group="Отображение",
     tooltip="Сохранять все Фибо циклы на графике. Если выключено - показывается только текущий цикл")
showPendingMax = input.bool(false, "Показывать PENDING MAX", group="Отображение",
    tooltip="Показывать неподтверждённый MAX (до касания 0.618)")
showLabels = input.bool(true, "Показывать сигналы Buy/Sell", group="Отображение")
showProfitPercent = input.bool(true, "Показывать % дохода на Sell", group="Отображение",
     tooltip="Отображать процент дохода рядом с меткой Sell")
showLocalMax = input.bool(true, "Показывать локальные MAX", group="Отображение",
     tooltip="Показывать локальные максимумы и их уровни 0.618 (пунктирные линии)")
showInfo = input.bool(true, "Показывать таблицу", group="Отображение")

// ============================================================================
// ПЕРЕМЕННЫЕ СОСТОЯНИЯ (объявляем рано, т.к. используются в поиске минимума)
// ============================================================================

// Бар начала нового поиска (после завершения предыдущего цикла)
var int searchStartBar = na
// Бар начала поиска MAX (не сбрасывается при использовании старого MIN!)
var int maxSearchStartBar = na

// Флаг что первый цикл уже начался
var bool firstCycleStarted = false

// Время первого бара графика (листинг)
var int listingTime = na
if barstate.isfirst
    listingTime := time

// Расчёт времени в миллисекундах: skipDaysAfterListing дней
skipMilliseconds = skipDaysAfterListing * 24 * 60 * 60 * 1000

// Проверка периода после листинга (по времени, не по барам)
isAfterListingPeriod = time >= (listingTime + skipMilliseconds)

// Находим первый бар после периода листинга
var int firstBarAfterListing = na
if isAfterListingPeriod and na(firstBarAfterListing)
    firstBarAfterListing := bar_index

// ============================================================================
// ЛОГИ ИНИЦИАЛИЗАЦИИ (на первом и последнем баре)
// ============================================================================

// Лог на ПЕРВОМ баре - проверка что индикатор загрузился
if barstate.isfirst
    log.info("🟢 INDICATOR LOADED! Symbol={0}, timeframe={1}", syminfo.tickerid, timeframe.period)
    log.info("📊 SETTINGS: lookback={0}, minGrowth={1}%, wickThreshold={2}%, skipDays={3}", 
         lookbackPeriod, minGrowthPercent, wickThreshold, skipDaysAfterListing)

// Лог на втором баре - базовая информация о графике
if bar_index == 1
    log.info("📈 CHART INFO: first bar_index=0, total bars will be known at end")

// Лог каждые 100 баров для отслеживания прогресса (только первые 500)
if bar_index <= 500 and bar_index % 100 == 0
    log.info("⏳ Processing bar {0}, isAfterListing={1}", bar_index, isAfterListingPeriod ? 1 : 0)

// Лог когда достигаем периода после листинга
if isAfterListingPeriod and bar_index == firstBarAfterListing
    log.info("✅ SKIP PERIOD ENDED: bar_index={0}, firstBarAfterListing={1}, skipDays={2}", bar_index, firstBarAfterListing, skipDaysAfterListing)

// Лог на последнем баре - итоговая информация
if barstate.islast
    log.info("🏁 LAST BAR REACHED: bar_index={0}, last_bar_index={1}, total_bars={2}", 
         bar_index, last_bar_index, bar_index + 1)
    if not isAfterListingPeriod
        log.warning("⚠️ CHART TOO SHORT! Not yet past {0} days after listing. Indicator inactive.", 
             skipDaysAfterListing)

// ============================================================================
// ФУНКЦИИ ДЛЯ ПРОВЕРКИ ТЕНЕЙ СВЕЧЕЙ
// ============================================================================

// Проверка нижней тени - для минимума
// Расчёт: процент падения от тела свечи до минимума
// Растущая свеча: (open - low) / open * 100%
// Падающая свеча: (close - low) / close * 100%
getLowerWickPercent(idx) =>
    isGreen = close[idx] > open[idx]
    bodyBottom = isGreen ? open[idx] : close[idx]
    bodyBottom > 0 ? ((bodyBottom - low[idx]) / bodyBottom) * 100 : 0.0

// Проверка верхней тени (пламя) - для максимума
// Расчёт: процент роста от тела свечи до максимума
// Растущая свеча: (high - close) / close * 100%
// Падающая свеча: (high - open) / open * 100%
getUpperWickPercent(idx, referenceMin) =>
    isGreen = close[idx] > open[idx]
    bodyTop = isGreen ? close[idx] : open[idx]
    bodyTop > 0 ? ((high[idx] - bodyTop) / bodyTop) * 100 : 0.0

// Версия без referenceMin (использует тот же расчёт)
getUpperWickPercentCandle(idx) =>
    isGreen = close[idx] > open[idx]
    bodyTop = isGreen ? close[idx] : open[idx]
    bodyTop > 0 ? ((high[idx] - bodyTop) / bodyTop) * 100 : 0.0

// ============================================================================
// ПОИСК ОПТИМАЛЬНОГО МИНИМУМА (с учетом тени)
// ============================================================================

// Ограничиваем lookback барами после листинга
barsAfterListing = isAfterListingPeriod and not na(firstBarAfterListing) ? bar_index - firstBarAfterListing + 1 : 0
dynamicLookbackRaw = na(searchStartBar) ? barsAfterListing : bar_index - searchStartBar + 1
// Ограничиваем lookback: не больше lookbackPeriod, не больше bar_index+1, не больше баров после листинга
dynamicLookback = math.max(1, math.min(math.min(math.min(lookbackPeriod, bar_index + 1), dynamicLookbackRaw), barsAfterListing))

// Выносим ta.lowestbars из тернарного оператора для согласованности
rawLowestBarCalc = ta.lowestbars(low, dynamicLookback)
rawLowestBar = dynamicLookback >= 1 ? rawLowestBarCalc : 0
rawLowestPrice = dynamicLookback >= 1 ? ta.lowest(low, dynamicLookback) : low

findOptimalMinimum() =>
    int resultBar = math.abs(nz(rawLowestBar, 0))
    float resultPrice = rawLowestPrice
    bool useBody = false
    
    lowerWick = getLowerWickPercent(resultBar)
    
    // DEBUG: логируем на последнем баре
    if barstate.islast
        log.info("🔍 findOptimalMinimum: rawLowestBar={0}, resultBar={1}, rawLowestPrice={2}", 
             rawLowestBar, resultBar, rawLowestPrice)
        log.info("🔍 findOptimalMinimum: lowerWick={0}%, threshold={1}%, dynamicLookback={2}", 
             lowerWick, wickThreshold, dynamicLookback)
        log.info("🔍 findOptimalMinimum: searchStartBar={0}, bar_index={1}", 
             na(searchStartBar) ? -1 : searchStartBar, bar_index)
    
    if lowerWick > wickThreshold
        foundBetter = false
        problemCandleBody = math.min(open[resultBar], close[resultBar])
        
        for i = 1 to 5
            if resultBar + i < dynamicLookback
                leftWick = getLowerWickPercent(resultBar + i)
                if leftWick <= wickThreshold and low[resultBar + i] < problemCandleBody
                    resultBar := resultBar + i
                    resultPrice := low[resultBar]
                    foundBetter := true
                    break
            if resultBar - i >= 0
                rightWick = getLowerWickPercent(resultBar - i)
                if rightWick <= wickThreshold and low[resultBar - i] < problemCandleBody
                    resultBar := resultBar - i
                    resultPrice := low[resultBar]
                    foundBetter := true
                    break
        
        if not foundBetter
            resultBar := math.abs(nz(rawLowestBar, 0))
            resultPrice := problemCandleBody
            useBody := true
    
    [resultBar, resultPrice, useBody]

[minBarOffset, minPrice, minUseBody] = findOptimalMinimum()

// ============================================================================
// СОСТОЯНИЯ ТОРГОВОЙ СИСТЕМЫ
// ============================================================================

var int STATE_SEARCHING_MIN = 0
var int STATE_WAITING_GROWTH = 1
var int STATE_FIBO_ACTIVE = 2
var int STATE_WAITING_RESET = 3

var int systemState = STATE_SEARCHING_MIN
var float confirmedMin = na
var int confirmedMinBar = na
var float confirmedMax = na
var int confirmedMaxBar = na
var float confirmedMaxRealHigh = na  // Реальный high бара с MAX (для сравнения при перехае)
var bool minUsesBody = false
var bool maxUsesBody = false

var int sellCount = 0
var bool touchedZone06_07 = false
var float prevConfirmedMax = na
var float prevConfirmedMin = na
var int prevConfirmedMaxBar = na
var int prevConfirmedMinBar = na

// MIN/MAX последнего цикла где был SELL — чтобы не повторять тот же Фибо
var float lastSoldMin = na
var float lastSoldMax = na

// MIN/MAX последнего ПОЛНОСТЬЮ завершённого цикла (Этап 1 + Этап 2)
// Чтобы не начинать новый цикл с тем же Фибо после полного завершения
var float lastCompletedMin = na
var float lastCompletedMax = na

// Флаг что уже был хотя бы один завершённый цикл (для отличия первого цикла после листинга от reset)
var bool hadCompletedCycle = false

// ============================================================================
// УРОВНИ ОРДЕРОВ (с возможностью сдвига)
// ============================================================================

var float orderLevel1 = 0.618
var float orderLevel2 = 0.5
var float orderLevel3 = 0.382

var float sellLevel1 = 0.786
var float sellLevel2 = 0.618
var float sellLevel3 = 0.5

// Этап торговли: 1 = начальный (0.618/0.5/0.382), 2 = после SELL#1 (0.5/0.382/0.236)
var int tradingStage = 1

var bool position1Open = false
var bool position2Open = false
var bool position3Open = false

// Флаги что позиции были куплены в этом цикле (для отображения)
var bool position1WasBought = false
var bool position2WasBought = false
var bool position3WasBought = false

// Флаг что в текущем цикле уже был SELL — запрещает повторные покупки до нового цикла
var bool cycleHadSell = false
// Флаг что в текущем цикле была покупка (для отображения MAX)
var bool cycleHadBuy = false
// Бар последней покупки — SELL разрешён только через 1+ бар после покупки
var int lastBuyBar = na

var float entryPrice1 = na
var float entryPrice2 = na
var float entryPrice3 = na

// Сохраняем MIN/MAX на момент открытия позиции для корректного отображения в tooltip
var float entryMin1 = na
var float entryMax1 = na
var int entryMinBar1 = na
var int entryMaxBar1 = na
var float entryMin2 = na
var float entryMax2 = na
var int entryMinBar2 = na
var int entryMaxBar2 = na
var float entryMin3 = na
var float entryMax3 = na
var int entryMinBar3 = na
var int entryMaxBar3 = na

var bool doResetOrders = false

// ============================================================================
// СТАТИСТИКА ПО ИНДИКАТОРУ (не Strategy Tester)
// ============================================================================

var float totalProfitLoss = 0.0       // Общая прибыль/убыток
var float grossProfit = 0.0           // Валовая прибыль (сумма всех прибыльных сделок)
var float grossLoss = 0.0             // Валовый убыток (сумма всех убыточных сделок)
var float maxEquity = 0.0             // Максимальный капитал (для расчета просадки)
var float maxDrawdown = 0.0           // Максимальная просадка
var int totalTrades = 0               // Всего сделок (каждый SELL = сделка)
var int profitableTrades = 0          // Прибыльных сделок
var float currentEquity = 0.0         // Текущий капитал (накопленная прибыль)
var int firstTradeTime = na           // Время первой сделки (timestamp)

// ============================================================================
// ПЕРЕМЕННЫЕ ДЛЯ ЛИНИЙ И ЛЕЙБЛОВ
// ============================================================================

var box box_1_000 = na
var box box_0_786 = na  // 78.6% - уровень SELL
var box box_0_618 = na
var box box_0_500 = na
var box box_0_382 = na
var box box_0_236 = na

var label label_fib_1_000 = na
var label label_fib_0_618 = na
var label label_fib_0_500 = na
var label label_fib_0_382 = na
var label label_fib_0_236 = na

var label label_min = na
var label label_max = na
var line line_pending_max = na      // Линия pending MAX
var label label_pending_max = na   // Метка pending MAX
var line line_pending_fib618 = na  // Линия уровня 0.618 для подтверждения

// Массивы для локальных MAX (до 5 локальных максимумов)
var float[] localMaxPrices = array.new_float(5, na)
var int[] localMaxBars = array.new_int(5, na)
var line[] localMaxLines = array.new_line(5, na)
var line[] localMax618Lines = array.new_line(5, na)
var label[] localMaxLabels = array.new_label(5, na)

var bool fiboWasDrawn = false
var int currentCycleId = 0
var int drawnCycleId = -1
var float drawnMax = na
var float drawnMin = na
var int drawnMaxBar = na

// Флаг для принудительной перерисовки Фибо
var bool forceRedraw = false

// Потенциальный MAX (ждёт подтверждения касанием 0.618)
var float pendingMaxPrice = na      // Цена потенциального MAX
var int pendingMaxBar = na          // Бар потенциального MAX
var bool pendingMaxUsesBody = false // Использует body вместо high
var bool hasPendingMax = false      // Есть ли неподтверждённый MAX
var bool preservePendingMax = false // Флаг: НЕ сбрасывать pendingMax в doResetOrders

// ============================================================================
// ЛОГИКА СОСТОЯНИЙ
// ============================================================================

if doResetOrders
    // ВАЖНО: НЕ сбрасываем уровни, этап и cycleHadSell если мы на Этапе 2 (после SELL на Этапе 1)
    // На Этапе 2 уровни и cycleHadSell уже установлены в логике SELL
    if tradingStage == 1
        orderLevel1 := 0.618
        orderLevel2 := 0.5
        orderLevel3 := 0.382
        sellLevel1 := 0.786
        sellLevel2 := 0.618
        sellLevel3 := 0.5
        cycleHadSell := false  // Новый цикл — разрешаем покупки
    // tradingStage НЕ трогаем - он управляется логикой SELL и isSameMax/isSameMin
    if tradingStage == 2
        log.info("🛡️ [doResetOrders] PRESERVED Stage 2: orderLevel1={0}, sellLevel1={1}", orderLevel1, sellLevel1)
    cycleHadBuy := false   // Сбрасываем — покупок в новом Фибо ещё не было
    lastBuyBar := na       // Сброс бара последней покупки
    // Сброс флагов покупок для нового цикла
    // ВАЖНО: НЕ сбрасываем если позиции ещё открыты (для корректного hadOnlyBuy1)
    if not position1Open and not position2Open and not position3Open
        position1WasBought := false
        position2WasBought := false
        position3WasBought := false
    // Сброс pending MAX - НО ТОЛЬКО если НЕ установлен preservePendingMax!
    if not preservePendingMax
        hasPendingMax := false
        pendingMaxPrice := na
        pendingMaxBar := na
        pendingMaxUsesBody := false
    else
        // Логируем что сохранили pending MAX
        log.info("🛡️ [doResetOrders] PRESERVED pendingMax: {0}, hasPendingMax: {1}", pendingMaxPrice, hasPendingMax)
        preservePendingMax := false  // Сбрасываем флаг после использования
    // Очистка локальных MAX
    for i = 0 to 4
        array.set(localMaxPrices, i, na)
        array.set(localMaxBars, i, na)
    doResetOrders := false

currentGrowth = confirmedMin > 0 ? ((high - confirmedMin) / confirmedMin) * 100 : 0
barsFromMinCalcRaw = na(confirmedMinBar) ? 1 : bar_index - confirmedMinBar
barsFromMinCalc = math.max(1, math.min(bar_index + 1, barsFromMinCalcRaw))

// ВАЖНО: Ограничиваем поиск MAX барами ПОСЛЕ maxSearchStartBar!
// maxSearchStartBar НЕ сбрасывается при использовании старого MIN (в отличие от searchStartBar)
// Это предотвращает использование старого MAX из предыдущего цикла
barsFromMaxSearchStart = na(maxSearchStartBar) ? barsFromMinCalc : math.max(1, bar_index - maxSearchStartBar)
// Берём минимум: либо от MIN, либо от maxSearchStartBar (что меньше)
barsForMaxSearch = math.min(barsFromMinCalc, barsFromMaxSearchStart)

maxPriceAfterMin = barsForMaxSearch >= 1 ? ta.highest(high, barsForMaxSearch) : high
maxBarAfterMin = barsForMaxSearch >= 1 ? ta.highestbars(high, barsForMaxSearch) : 0

// Рост от максимума после MIN (для проверки 100%)
maxGrowthAfterMin = confirmedMin > 0 and not na(maxPriceAfterMin) ? ((maxPriceAfterMin - confirmedMin) / confirmedMin) * 100 : 0

processMaxAfterMin() =>
    if na(confirmedMinBar) or barsFromMinCalc < 2
        [float(na), int(na), false]
    else
        maxBarIdx = math.abs(nz(maxBarAfterMin, 0))
        upperWick = getUpperWickPercent(maxBarIdx, confirmedMin)
        usesBody = false
        finalPrice = maxPriceAfterMin
        finalBar = bar_index + nz(maxBarAfterMin, 0)
        
        if upperWick > wickThreshold
            foundBetter = false
            bestPrice = 0.0
            bestBar = maxBarIdx
            problemCandleBody = math.max(open[maxBarIdx], close[maxBarIdx])
            
            for i = 1 to 5
                if maxBarIdx + i < barsFromMinCalc
                    leftWick = getUpperWickPercent(maxBarIdx + i, confirmedMin)
                    if leftWick <= wickThreshold and high[maxBarIdx + i] > problemCandleBody
                        bestBar := maxBarIdx + i
                        bestPrice := high[maxBarIdx + i]
                        foundBetter := true
                if maxBarIdx - i >= 0
                    rightWick = getUpperWickPercent(maxBarIdx - i, confirmedMin)
                    if rightWick <= wickThreshold and high[maxBarIdx - i] > problemCandleBody
                        bestBar := maxBarIdx - i
                        bestPrice := high[maxBarIdx - i]
                        foundBetter := true
            
            if foundBetter
                finalBar := bar_index - bestBar
                finalPrice := bestPrice
            else
                finalPrice := problemCandleBody
                usesBody := true
        
        [finalPrice, finalBar, usesBody]

[calcMaxP, calcMaxB, calcMaxBody] = processMaxAfterMin()

// ============================================================================
// ОБНОВЛЕНИЕ СОСТОЯНИЙ НА КАЖДОМ БАРЕ
// ============================================================================

if not firstCycleStarted and isAfterListingPeriod
    searchStartBar := firstBarAfterListing  // Ищем MIN начиная с первого бара после листинга
    maxSearchStartBar := firstBarAfterListing  // MAX тоже ищем с первого бара
    firstCycleStarted := true
    log.info("🚀 FIRST CYCLE STARTED: bar_index={0}, skipDays={1}, searchStartBar={2}", bar_index, skipDaysAfterListing, searchStartBar)

// Для ПЕРВОГО цикла после листинга: ищем MIN только когда от него уже есть рост 100%
// Вычисляем рост от найденного минимума до текущего максимума в периоде
initialGrowthFromMin = minPrice > 0 ? ((ta.highest(high, dynamicLookback) - minPrice) / minPrice) * 100 : 0

if isAfterListingPeriod and (systemState == STATE_SEARCHING_MIN or systemState == STATE_WAITING_GROWTH)
    minBarAbsolute = bar_index - minBarOffset
    // Минимум должен быть после листинга И после searchStartBar (если установлен)
    minIsAfterListing = not na(firstBarAfterListing) and minBarAbsolute >= firstBarAfterListing
    minIsAfterSearchStart = na(searchStartBar) or minBarAbsolute >= searchStartBar
    
    // НОВАЯ ЛОГИКА: Два условия для принятия нового MIN:
    // Условие 1: Новый MIN ниже предыдущего подтверждённого MIN
    // Условие 2: Новый MIN выше предыдущего MIN, НО новый MAX ниже предыдущего MAX (при росте 100%)
    
    // Локальный MAX в текущем диапазоне поиска (для проверки Условия 2)
    localMaxInRange = dynamicLookback >= 1 ? ta.highest(high, dynamicLookback) : high
    
    // Условие 1: MIN ниже предыдущего (или первый раз - prevConfirmedMin = na)
    isCondition1 = na(prevConfirmedMin) or minPrice < prevConfirmedMin
    
    // Условие 2: MIN выше предыдущего MIN, но MAX ниже предыдущего MAX (при 100%+ росте)
    growthForCondition2 = minPrice > 0 ? ((localMaxInRange - minPrice) / minPrice) * 100 : 0
    isCondition2 = not na(prevConfirmedMin) and not na(prevConfirmedMax) and 
         minPrice > prevConfirmedMin and localMaxInRange < prevConfirmedMax and growthForCondition2 >= minGrowthPercent
    
    // Хотя бы одно условие должно быть выполнено
    minMeetsConditions = isCondition1 or isCondition2
    
    // Для ПЕРВОГО цикла после листинга (ещё не было завершённых циклов): 
    // MIN устанавливается ТОЛЬКО если от него уже есть рост 100%
    // После FULL RESET - это НЕ первый цикл, можно искать MIN обычным способом
    isFirstCycleEver = not hadCompletedCycle and na(confirmedMin)
    canSetMinFirstCycle = not isFirstCycleEver or initialGrowthFromMin >= minGrowthPercent
    
    if minIsAfterListing and minIsAfterSearchStart and minMeetsConditions and canSetMinFirstCycle
        // Проверяем также что текущий confirmedMin валиден (если есть)
        currentMinIsValid = na(confirmedMinBar) or (not na(firstBarAfterListing) and confirmedMinBar >= firstBarAfterListing and (na(searchStartBar) or confirmedMinBar >= searchStartBar))
        
        // ВАЖНО: При isCondition2 используем СТАРЫЙ MIN (prevConfirmedMin), а не новый!
        // isCondition1: новый MIN ниже → берём НОВЫЙ MIN
        // isCondition2: новый MIN выше, но MAX ниже → продолжаем со СТАРЫМ MIN
        useOldMinSearch = isCondition2 and not isCondition1
        
        if not currentMinIsValid
            // Текущий минимум устарел, заменяем
            if useOldMinSearch and not na(prevConfirmedMin)
                // При Условии 2 используем старый MIN
                confirmedMin := prevConfirmedMin
                confirmedMinBar := prevConfirmedMinBar
                minUsesBody := false
                // ВАЖНО: Обновляем searchStartBar чтобы старый MIN был валидным
                searchStartBar := prevConfirmedMinBar
                log.info("📍 NEW MIN (old was invalid, COND2: keep prevMin): price={0}, minBar={1}, searchStartBar updated", prevConfirmedMin, prevConfirmedMinBar)
            else
                confirmedMin := minPrice
                confirmedMinBar := minBarAbsolute
                minUsesBody := minUseBody
                log.info("📍 NEW MIN (old was invalid): price={0}, minBar={1}, bar_index={2}, prev MIN reset", minPrice, minBarAbsolute, bar_index)
            systemState := STATE_WAITING_GROWTH
            // Сбрасываем предыдущий MIN - он больше не работает
            prevConfirmedMin := na
            prevConfirmedMax := na
            prevConfirmedMinBar := na
            prevConfirmedMaxBar := na
        else if na(confirmedMin) or minPrice < confirmedMin
            // Для ПЕРВОГО цикла с ростом 100% - сразу логируем что нашли
            if isFirstCycleEver and initialGrowthFromMin >= minGrowthPercent
                log.info("🎯 FIRST CYCLE MIN with 100%+ growth: price={0}, minBar={1}, growth={2}%", minPrice, minBarAbsolute, initialGrowthFromMin)
            
            if useOldMinSearch and not na(prevConfirmedMin)
                // При Условии 2 используем старый MIN
                confirmedMin := prevConfirmedMin
                confirmedMinBar := prevConfirmedMinBar
                minUsesBody := false
                // ВАЖНО: Обновляем searchStartBar чтобы старый MIN был валидным
                searchStartBar := prevConfirmedMinBar
                log.info("📍 KEEPING OLD MIN (COND2: higher MIN + lower MAX): prevMin={0}, prevMinBar={1}, localMax={2}, prevMax={3}, searchStartBar updated", prevConfirmedMin, prevConfirmedMinBar, localMaxInRange, prevConfirmedMax)
            else
                // При Условии 1 используем новый MIN
                confirmedMin := minPrice
                confirmedMinBar := minBarAbsolute
                minUsesBody := minUseBody
                log.info("📍 NEW MIN FOUND (COND1: lower MIN): price={0}, minBar={1}, localMax={2}, prevMin={3}", minPrice, minBarAbsolute, localMaxInRange, na(prevConfirmedMin) ? 0.0 : prevConfirmedMin)
            systemState := STATE_WAITING_GROWTH
            // Сбрасываем предыдущий MIN - он больше не работает
            prevConfirmedMin := na
            prevConfirmedMax := na
            prevConfirmedMinBar := na
            prevConfirmedMaxBar := na

if systemState == STATE_WAITING_GROWTH
    // Проверка: минимум должен быть после листинга И после searchStartBar (если установлен)
    minIsValidListing = not na(confirmedMinBar) and not na(firstBarAfterListing) and confirmedMinBar >= firstBarAfterListing
    minIsValidSearchStart = na(searchStartBar) or (not na(confirmedMinBar) and confirmedMinBar >= searchStartBar)
    minIsValid = minIsValidListing and minIsValidSearchStart
    
    if not minIsValid
        // Минимум устарел (был найден до листинга или до reset'а), сбрасываем и ищем заново
        log.info("⚠️ MIN INVALID: minBar={0} < skipDays={1} or searchStartBar={2}, resetting", 
             na(confirmedMinBar) ? -1 : confirmedMinBar, na(firstBarAfterListing) ? -1 : firstBarAfterListing, na(searchStartBar) ? -1 : searchStartBar)
        confirmedMin := na
        confirmedMinBar := na
        systemState := STATE_SEARCHING_MIN
    else
        // Проверяем есть ли новый более низкий MIN с учётом тени
        currentBarWick = getLowerWickPercent(0)
        currentBarBodyMin = math.min(open, close)
        // Если тень большая - используем тело свечи, иначе low
        currentBarMinPrice = currentBarWick > wickThreshold ? currentBarBodyMin : low
        
        if currentBarMinPrice < confirmedMin
            // Цена упала НИЖЕ текущего MIN - обновляем MIN на новый
            log.info("📉 NEW LOWER MIN in WAITING_GROWTH: old={0}, new={1}, bar={2}, wick={3}%, useBody={4}", 
                 confirmedMin, currentBarMinPrice, bar_index, currentBarWick, currentBarWick > wickThreshold)
            confirmedMin := currentBarMinPrice
            confirmedMinBar := bar_index
            minUsesBody := currentBarWick > wickThreshold
        else if maxGrowthAfterMin >= minGrowthPercent
            if not na(calcMaxP)
                // ВАЖНО: Если уже есть PENDING MAX который ВЫШЕ нового - НЕ перезаписываем!
                // Это важно когда новый цикл начался со старым MAX (из prevConfirmedMax)
                shouldSetNewPendingMax = not hasPendingMax or calcMaxP > pendingMaxPrice
                
                // DEBUG: показываем почему решили установить или не установить новый MAX
                log.info("🔍 100% GROWTH CHECK: hasPendingMax={0}, pendingMaxPrice={1}, calcMaxP={2}, shouldSet={3}", 
                     hasPendingMax, hasPendingMax ? pendingMaxPrice : 0.0, calcMaxP, shouldSetNewPendingMax)
                
                if shouldSetNewPendingMax
                    // ВАЖНО: Первый MAX тоже должен быть PENDING и ждать подтверждения касанием 0.618!
                    // Не делаем confirmedMax := calcMaxP сразу - сначала ставим как PENDING
                    pendingMaxPrice := calcMaxP
                    pendingMaxBar := calcMaxB
                    pendingMaxUsesBody := calcMaxBody
                    hasPendingMax := true
                    
                    // Барьер для определения нового перехая
                    if calcMaxBody
                        confirmedMaxRealHigh := calcMaxP
                    else
                        confirmedMaxRealHigh := high[bar_index - calcMaxB]
                    
                    // Расчёт уровня 0.618 для подтверждения
                    expectedFib618 = confirmedMin + (calcMaxP - confirmedMin) * 0.618
                    log.info("════════════════════════════════════════════════════════════")
                    log.info("📊 [MAX EVENT] TYPE: 100% GROWTH - FIRST PENDING MAX")
                    log.info("📊 [MAX EVENT] REASON: Growth from MIN reached {0}% (threshold: {1}%)", maxGrowthAfterMin, minGrowthPercent)
                    log.info("📊 [MAX EVENT] PENDING MAX: {0} at bar {1}", calcMaxP, calcMaxB)
                    log.info("📊 [MAX EVENT] MIN: {0} at bar {1}", confirmedMin, confirmedMinBar)
                    log.info("📊 [MAX EVENT] Uses body: {0}, Barrier: {1}", calcMaxBody, confirmedMaxRealHigh)
                    log.info("📊 [MAX EVENT] Level 0.618 for confirmation: {0}", expectedFib618)
                    log.info("📊 [MAX EVENT] STATUS: Waiting for price to touch 0.618 level")
                    log.info("════════════════════════════════════════════════════════════")
                else
                    log.info("📊 [MAX EVENT] TYPE: 100% GROWTH - KEEPING EXISTING PENDING MAX")
                    log.info("📊 [MAX EVENT] REASON: Existing PENDING MAX {0} > new found {1}", pendingMaxPrice, calcMaxP)
                
                systemState := STATE_FIBO_ACTIVE
                touchedZone06_07 := false
                sellCount := 0
                doResetOrders := true
                hadCompletedCycle := true  // Первый цикл завершён - теперь можно искать MIN обычным способом
                // Сбрасываем предыдущий MIN - новый цикл начался
                prevConfirmedMin := na
                prevConfirmedMax := na
                prevConfirmedMinBar := na
                prevConfirmedMaxBar := na
                // ВАЖНО: Сброс на Этап 1
                tradingStage := 1
                orderLevel1 := 0.618
                orderLevel2 := 0.5
                orderLevel3 := 0.382
                sellLevel1 := 0.786
                sellLevel2 := 0.618
                sellLevel3 := 0.5
                cycleHadSell := false
                lastSoldMin := na
                lastSoldMax := na
                // Новый цикл — сбрасываем завершённый Фибо
                lastCompletedMin := na
                lastCompletedMax := na
                // НЕ закрываем позиции — пусть strategy.exit() сработает на take-profit уровне
                // Позиции из старого цикла продолжают ждать своего TP
                // Только сбрасываем флаги если позиции действительно должны быть закрыты
                // position1Open := false
                // position2Open := false
                // position3Open := false
                forceRedraw := true  // Принудительная отрисовка нового Фибо

// Проверка валидности MIN в STATE_FIBO_ACTIVE (на случай если searchStartBar изменился после SELL)
if systemState == STATE_FIBO_ACTIVE
    fiboMinIsValid = na(searchStartBar) or (not na(confirmedMinBar) and confirmedMinBar >= searchStartBar)
    fiboMinIsAfterListing = not na(confirmedMinBar) and not na(firstBarAfterListing) and confirmedMinBar >= firstBarAfterListing
    
    if not fiboMinIsValid or not fiboMinIsAfterListing
        log.info("⚠️ FIBO MIN INVALID: minBar={0}, searchStartBar={1}, skipDays={2}, resetting cycle", 
             na(confirmedMinBar) ? -1 : confirmedMinBar, na(searchStartBar) ? -1 : searchStartBar, na(firstBarAfterListing) ? -1 : firstBarAfterListing)
        // Не закрываем позиции — пусть strategy.exit() сработает на take-profit
        confirmedMin := na
        confirmedMinBar := na
        confirmedMax := na
        confirmedMaxBar := na
        systemState := STATE_SEARCHING_MIN
        sellCount := 0
        touchedZone06_07 := false
        position1Open := false
        position2Open := false
        position3Open := false
        doResetOrders := true

// FULL RESET в STATE_FIBO_ACTIVE: если цена падает на 2%+ ниже MIN - сбрасываем и ищем новый MIN
// ВАЖНО: Если есть открытые позиции и стоп-лосс ВЫКЛЮЧЕН - НЕ делаем FULL RESET!
// Позиции остаются открытыми и ждут SELL на текущем Fibo
hasOpenPositionsForReset = position1Open or position2Open or position3Open
canDoFullReset = not hasOpenPositionsForReset or enableStopLoss  // Можно сбросить только если нет позиций ИЛИ стоп-лосс включён

if systemState == STATE_FIBO_ACTIVE and not na(confirmedMin) and low < confirmedMin * 0.98 and canDoFullReset
    log.info("📉 FULL RESET (FIBO_ACTIVE): low={0} < min*0.98={1}, starting new search", low, confirmedMin * 0.98)
    currentCycleId := currentCycleId + 1
    
    // Закрываем все открытые позиции если есть И стоп-лосс включён
    if hasOpenPositionsForReset and enableStopLoss
        strategy.close_all(comment="FULL RESET - price below MIN")
        log.info("🛑 FULL RESET: Закрыты все позиции")
        position1Open := false
        position2Open := false
        position3Open := false
    
    confirmedMin := na
    confirmedMinBar := na
    confirmedMax := na
    confirmedMaxBar := na
    confirmedMaxRealHigh := na
    prevConfirmedMin := na
    prevConfirmedMax := na
    prevConfirmedMinBar := na
    prevConfirmedMaxBar := na
    lastSoldMin := na
    lastSoldMin := na
    lastSoldMax := na
    // Новый цикл — сбрасываем завершённый Фибо
    lastCompletedMin := na
    lastCompletedMax := na
    searchStartBar := bar_index
    maxSearchStartBar := bar_index  // Также сбрасываем для поиска MAX
    systemState := STATE_SEARCHING_MIN
    sellCount := 0
    touchedZone06_07 := false
    // Сбрасываем positionXOpen только если стоп-лосс включён (позиции уже закрыты выше)
    // Если стоп-лосс выключен — позиции остаются открытыми
    if enableStopLoss
        position1Open := false
        position2Open := false
        position3Open := false
    doResetOrders := true
    cycleHadSell := false
    // Сброс pending MAX
    hasPendingMax := false
    pendingMaxPrice := na
    pendingMaxBar := na
    pendingMaxUsesBody := false
    
    // Удаляем Fibo элементы с графика (только если не сохраняем историю)
    if not showAllFiboHistory
        box.delete(box_1_000)
        box.delete(box_0_786)
        box.delete(box_0_618)
        box.delete(box_0_500)
        box.delete(box_0_382)
        box.delete(box_0_236)
        label.delete(label_fib_1_000)
        label.delete(label_fib_0_618)
        label.delete(label_fib_0_500)
        label.delete(label_fib_0_382)
        label.delete(label_fib_0_236)
        label.delete(label_min)
        label.delete(label_max)
    
    box_1_000 := na
    box_0_786 := na
    box_0_618 := na
    box_0_500 := na
    box_0_382 := na
    box_0_236 := na
    fiboWasDrawn := false
    drawnCycleId := -1

else if systemState == STATE_FIBO_ACTIVE and not na(confirmedMin) and low < confirmedMin * 0.98 and not canDoFullReset
    // Есть открытые позиции и стоп-лосс выключен - НЕ делаем FULL RESET
    log.info("⚠️ FULL RESET BLOCKED: low={0} < min*0.98={1}, but positions open and stopLoss disabled", low, confirmedMin * 0.98)

// ============================================================================
// ФУНКЦИЯ РАСЧЕТА УРОВНЕЙ ФИБОНАЧЧИ (определена здесь для использования в pending MAX)
// ============================================================================

// Функция для расчета уровня Фибоначчи (линейный или логарифмический)
// fibRatio: 0.0 = max, 1.0 = min, 0.382 = 61.8% уровень, 0.5 = 50%, 0.618 = 38.2%
getFibLevel(fibRatio, minVal, maxVal, useLog) =>
    if useLog and minVal > 0 and maxVal > minVal
        logMin = math.log(minVal)
        logMax = math.log(maxVal)
        logRange = logMax - logMin
        math.exp(logMax - logRange * fibRatio)
    else
        linearRange = maxVal - minVal
        maxVal - linearRange * fibRatio

// ============================================================================
// ЛОГИКА ПОТЕНЦИАЛЬНОГО MAX (ждёт подтверждения касанием 0.618)
// ============================================================================

// Функция добавления локального MAX в массив (сдвигает старые вниз)
addLocalMax(float price, int barIdx) =>
    // Сдвигаем все элементы вниз (удаляем самый старый)
    for i = 4 to 1
        array.set(localMaxPrices, i, array.get(localMaxPrices, i - 1))
        array.set(localMaxBars, i, array.get(localMaxBars, i - 1))
    // Добавляем новый в начало
    array.set(localMaxPrices, 0, price)
    array.set(localMaxBars, 0, barIdx)

// Функция очистки локальных MAX
clearLocalMaxArrays() =>
    for i = 0 to 4
        array.set(localMaxPrices, i, na)
        array.set(localMaxBars, i, na)

// Функция удаления линий локальных MAX с графика
deleteLocalMaxLines() =>
    for i = 0 to 4
        existingLine = array.get(localMaxLines, i)
        existing618Line = array.get(localMax618Lines, i)
        existingLabel = array.get(localMaxLabels, i)
        if not na(existingLine)
            line.delete(existingLine)
        if not na(existing618Line)
            line.delete(existing618Line)
        if not na(existingLabel)
            label.delete(existingLabel)
        array.set(localMaxLines, i, na)
        array.set(localMax618Lines, i, na)
        array.set(localMaxLabels, i, na)

// Определяем текущий MAX для сравнения (либо pendingMax, либо РЕАЛЬНЫЙ high бара с MAX)
// Используем confirmedMaxRealHigh чтобы не пропустить ситуацию когда тело < high
currentMaxForComparison = hasPendingMax ? pendingMaxPrice : nz(confirmedMaxRealHigh, confirmedMax)

// Проверяем есть ли новый потенциальный MAX
if systemState == STATE_FIBO_ACTIVE and high > currentMaxForComparison
    upperWick = getUpperWickPercent(0, confirmedMin)
    log.info("🔺 NEW HIGH CHECK: high={0} > maxForComparison={1}, wick={2}%, threshold={3}%", high, currentMaxForComparison, upperWick, wickThreshold)
    newMaxPrice = high
    newMaxBar = bar_index
    newMaxUsesBody = false
    
    // Ищем лучший MAX от MIN до текущего бара (не от предыдущего MAX!)
    barsToSearch = bar_index - confirmedMinBar
    bestHighPrice = 0.0
    bestHighBar = bar_index
    foundGoodCandle = false
    
    if upperWick <= wickThreshold
        bestHighPrice := high
        bestHighBar := bar_index
        foundGoodCandle := true
    
    // Ищем во всём диапазоне от MIN до текущего бара
    for i = 1 to barsToSearch
        checkWick = getUpperWickPercent(i, confirmedMin)
        if checkWick <= wickThreshold and high[i] > bestHighPrice
            bestHighPrice := high[i]
            bestHighBar := bar_index - i
            foundGoodCandle := true
    
    if foundGoodCandle
        newMaxPrice := bestHighPrice
        newMaxBar := bestHighBar
        log.info("🔍 Found best MAX: bar={0}, price={1}, barsSearched={2}", bestHighBar, bestHighPrice, barsToSearch)
    else
        maxHighPrice = high
        maxHighBar = 0
        problemCandleBody = math.max(open[0], close[0])
        
        // Ищем во всём диапазоне
        for i = 1 to barsToSearch
            if high[i] > maxHighPrice
                maxHighPrice := high[i]
                maxHighBar := i
        
        foundNeighborWithWick = false
        for i = 1 to 5
            if i <= barsToSearch
                neighborWick = getUpperWickPercent(i, confirmedMin)
                if neighborWick <= wickThreshold and high[i] > problemCandleBody
                    newMaxPrice := high[i]
                    newMaxBar := bar_index - i
                    foundNeighborWithWick := true
                    log.info("🔍 Found neighbor with wick > body: bar-{0}, price={1}", i, high[i])
                    break
        
        if not foundNeighborWithWick
            newMaxPrice := problemCandleBody
            newMaxBar := bar_index
            newMaxUsesBody := true
            log.info("⚠️ No good neighbor found, using current body: {0}", problemCandleBody)
    
    // НЕ сохраняем старые pending MAX как локальные - показываем только подтверждённый MAX
    // Старый pending MAX просто заменяется новым
    
    // Сохраняем как ПОТЕНЦИАЛЬНЫЙ MAX (ждёт подтверждения)
    oldPendingMax = pendingMaxPrice
    pendingMaxPrice := newMaxPrice
    pendingMaxBar := newMaxBar
    pendingMaxUsesBody := newMaxUsesBody
    hasPendingMax := true
    forceRedraw := true  // Перерисовать Фибо с новым pending MAX
    
    // Расчёт уровня 0.618 для подтверждения
    expectedFib618New = confirmedMin + (newMaxPrice - confirmedMin) * 0.618
    log.info("════════════════════════════════════════════════════════════")
    log.info("📊 [MAX EVENT] TYPE: NEW HIGH (ПЕРЕХАЙ) - NEW PENDING MAX")
    log.info("📊 [MAX EVENT] REASON: high={0} > barrier={1}", high, currentMaxForComparison)
    log.info("📊 [MAX EVENT] OLD PENDING MAX: {0}", na(oldPendingMax) ? 0.0 : oldPendingMax)
    log.info("📊 [MAX EVENT] NEW PENDING MAX: {0} at bar {1}", newMaxPrice, newMaxBar)
    log.info("📊 [MAX EVENT] MIN: {0} at bar {1}", confirmedMin, confirmedMinBar)
    log.info("📊 [MAX EVENT] Uses body: {0}, Upper wick: {1}%", newMaxUsesBody, upperWick)
    log.info("📊 [MAX EVENT] Level 0.618 for confirmation: {0}", expectedFib618New)
    log.info("📊 [MAX EVENT] STATUS: Waiting for price to touch 0.618 level")
    log.info("════════════════════════════════════════════════════════════")

// Проверяем подтверждение потенциального MAX (касание уровня 0.618)
// ВАЖНО: Не подтверждаем новый MAX пока есть открытые позиции - сначала нужен SELL
hasOpenPositions = position1Open or position2Open or position3Open

// Логируем блокировку подтверждения MAX из-за открытых позиций
if hasPendingMax and systemState == STATE_FIBO_ACTIVE and hasOpenPositions
    pending_fib_0618_check = getFibLevel(0.382, confirmedMin, pendingMaxPrice, useLogScale)
    if low <= pending_fib_0618_check
        log.info("⏸️ PENDING MAX BLOCKED: waiting for SELL first (pos1={0}, pos2={1}, pos3={2})", position1Open, position2Open, position3Open)

if hasPendingMax and systemState == STATE_FIBO_ACTIVE and not hasOpenPositions
    // Рассчитываем уровень 0.618 от pendingMax до confirmedMin
    pending_fib_0618 = getFibLevel(0.382, confirmedMin, pendingMaxPrice, useLogScale)  // 0.618 от MAX = 1 - 0.618 = 0.382 для getFibLevel
    
    // Если цена коснулась 0.618 — подтверждаем перехай
    if low <= pending_fib_0618
        log.info("════════════════════════════════════════════════════════════")
        log.info("📊 [MAX EVENT] TYPE: PENDING MAX CONFIRMED!")
        log.info("📊 [MAX EVENT] REASON: low={0} <= fib_0.618={1}", low, pending_fib_0618)
        log.info("📊 [MAX EVENT] CONFIRMED MAX: {0} at bar {1}", pendingMaxPrice, pendingMaxBar)
        log.info("📊 [MAX EVENT] MIN: {0}", confirmedMin)
        log.info("📊 [MAX EVENT] STATUS: Trading now ALLOWED from this MAX!")
        log.info("════════════════════════════════════════════════════════════")
        
        // Теперь выполняем логику перехая
        newMaxPrice = pendingMaxPrice
        newMaxBar = pendingMaxBar
        newMaxUsesBody = pendingMaxUsesBody
        
        // Сбрасываем pending
        hasPendingMax := false
        pendingMaxPrice := na
        pendingMaxBar := na
        pendingMaxUsesBody := false
        
        // Очищаем локальные MAX - они больше не нужны после подтверждения
        clearLocalMaxArrays()
        deleteLocalMaxLines()
        
        if sellCount >= 1
            currentCycleId := currentCycleId + 1
            log.info("🔄 NEW CYCLE after SELL+перехай: cycleId={0}, oldMax={1}, SAME MIN={2}", 
                 currentCycleId, confirmedMax, confirmedMin)
            
            // Удаляем старые Fibo элементы с графика (только если не сохраняем историю)
            if not showAllFiboHistory
                box.delete(box_1_000)
                box.delete(box_0_786)
                box.delete(box_0_618)
                box.delete(box_0_500)
                box.delete(box_0_382)
                box.delete(box_0_236)
                label.delete(label_fib_1_000)
                label.delete(label_fib_0_618)
                label.delete(label_fib_0_500)
                label.delete(label_fib_0_382)
                label.delete(label_fib_0_236)
                label.delete(label_min)
                label.delete(label_max)
            
            box_1_000 := na
            box_0_786 := na
            box_0_618 := na
            box_0_500 := na
            box_0_382 := na
            box_0_236 := na
            label_fib_1_000 := na
            label_fib_0_618 := na
            label_fib_0_500 := na
            label_fib_0_382 := na
            label_fib_0_236 := na
            label_min := na
            label_max := na
            fiboWasDrawn := false
            drawnCycleId := -1
            drawnMaxBar := na
            
            // Проверяем был ли новый минимум с момента последнего SELL
            // ДВА УСЛОВИЯ для нового MIN:
            // Условие 1: Новый MIN ниже текущего MIN
            // Условие 2: Новый MIN выше текущего MIN, НО новый MAX ниже текущего MAX (при росте 100%)
            newLowerMinFoundFibo = false
            newLowerMinPriceFibo = confirmedMin
            newLowerMinBarFibo = confirmedMinBar
            newLowerMinUsesBodyFibo = minUsesBody
            
            // Текущий MAX для проверки Условия 2 (это newMaxPrice - уже вычислен выше)
            currentMaxForCheck = newMaxPrice
            oldMaxForCheck = confirmedMax  // Старый MAX ДО перехая
            
            // Ищем минимум с момента searchStartBar до текущего бара
            barsToSearchMinFibo = na(searchStartBar) ? 0 : bar_index - searchStartBar + 1
            if barsToSearchMinFibo > 0
                for i = 0 to math.min(barsToSearchMinFibo - 1, 100)
                    candidateMinPrice = low[i]
                    candidateMinWick = getLowerWickPercent(i)
                    if candidateMinWick > wickThreshold
                        candidateMinPrice := math.min(open[i], close[i])
                    
                    // Условие 1: MIN ниже текущего
                    isCond1Fibo = candidateMinPrice < confirmedMin
                    
                    // Условие 2: MIN выше текущего, но новый MAX ниже старого MAX + рост 100%
                    growthFibo = candidateMinPrice > 0 ? ((currentMaxForCheck - candidateMinPrice) / candidateMinPrice) * 100 : 0
                    isCond2Fibo = candidateMinPrice > confirmedMin and currentMaxForCheck < oldMaxForCheck and growthFibo >= minGrowthPercent
                    
                    if isCond1Fibo
                        // Только если MIN действительно ниже
                        if candidateMinWick <= wickThreshold
                            newLowerMinPriceFibo := low[i]
                            newLowerMinBarFibo := bar_index - i
                            newLowerMinUsesBodyFibo := false
                            newLowerMinFoundFibo := true
                        else
                            bodyMinFibo = math.min(open[i], close[i])
                            if bodyMinFibo < newLowerMinPriceFibo
                                newLowerMinPriceFibo := bodyMinFibo
                                newLowerMinBarFibo := bar_index - i
                                newLowerMinUsesBodyFibo := true
                                newLowerMinFoundFibo := true
            
            if newLowerMinFoundFibo
                log.info("📍 FOUND LOWER MIN since SELL (FIBO): price={0}, bar={1} (was {2})", newLowerMinPriceFibo, newLowerMinBarFibo, confirmedMin)
                confirmedMin := newLowerMinPriceFibo
                confirmedMinBar := newLowerMinBarFibo
                minUsesBody := newLowerMinUsesBodyFibo
            else
                log.info("📍 KEEPING SAME MIN (no lower found): minPrice={0}, minBar={1}", confirmedMin, confirmedMinBar)
            
            confirmedMax := newMaxPrice
            confirmedMaxBar := newMaxBar
            // Если MAX использует body, барьер = body
            if newMaxUsesBody
                confirmedMaxRealHigh := newMaxPrice
            else
                confirmedMaxRealHigh := high[bar_index - newMaxBar]
            maxUsesBody := newMaxUsesBody
            sellCount := 0
            touchedZone06_07 := false
            
            // Не закрываем позиции — пусть strategy.exit() сработает на take-profit
            // Не сбрасываем positionXOpen чтобы отслеживать открытые позиции
            
            doResetOrders := true
            // При SAME MIN разрешаем использовать старый MIN - сдвигаем searchStartBar
            searchStartBar := confirmedMinBar
            
            // ВАЖНО: Проверяем, это НОВЫЙ MAX или тот же самый что был при SELL/COMPLETED
            // Если MAX тот же (не изменился) - это не перехай, продолжаем на Этапе 2 или блокируем
            isSameMaxAsSold = not na(lastSoldMax) and math.abs(newMaxPrice - lastSoldMax) < 0.0001
            isSameMinAsCompleted = not na(lastCompletedMin) and math.abs(confirmedMin - lastCompletedMin) < 0.0001
            isSameMaxAsCompleted = not na(lastCompletedMax) and math.abs(newMaxPrice - lastCompletedMax) < 0.0001
            isAlreadyCompleted = isSameMinAsCompleted and isSameMaxAsCompleted
            
            if isAlreadyCompleted
                // Этот Фибо уже полностью отторгован (Stage 1 + Stage 2) - НЕ сбрасываем
                log.warning("⛔ MAX UPDATE BLOCKED: MIN={0}, MAX={1} already completed", confirmedMin, newMaxPrice)
            else if isSameMaxAsSold
                // MAX не изменился - продолжаем на Этапе 2 (не сбрасываем)
                log.info("📊 SAME MAX AS SOLD ({0}): continuing on Stage 2, cycleId={1}", newMaxPrice, currentCycleId)
                // Устанавливаем уровни Этапа 2
                tradingStage := 2
                orderLevel1 := 0.5
                orderLevel2 := 0.382
                orderLevel3 := 0.236
                sellLevel1 := 0.618
                sellLevel2 := 0.5
                sellLevel3 := 0.382
                cycleHadSell := false
                // НЕ сбрасываем lastSoldMin/Max - они нужны для проверки
            else
                // Это ПЕРЕХАЙ - новый MAX выше старого, сброс на Этап 1
                tradingStage := 1
                orderLevel1 := 0.618
                orderLevel2 := 0.5
                orderLevel3 := 0.382
                sellLevel1 := 0.786
                sellLevel2 := 0.618
                sellLevel3 := 0.5
                cycleHadSell := false
                lastSoldMin := na
                lastSoldMax := na
                // Новый MAX — сбрасываем завершённый Фибо ТОЛЬКО если это действительно НОВЫЙ MAX
                // (т.е. выше lastCompletedMax)
                if na(lastCompletedMax) or newMaxPrice > lastCompletedMax + 0.0001
                    lastCompletedMin := na
                    lastCompletedMax := na
                    log.info("🔄 ПЕРЕХАЙ ПОСЛЕ SELL: сброс на Этап 1, cycleId={0}, newMax={1} > oldSoldMax", currentCycleId, newMaxPrice)
                else
                    log.info("🔄 ПЕРЕХАЙ НО ТОТ ЖЕ MAX: cycleId={0}, newMax={1}, lastCompletedMax={2}", currentCycleId, newMaxPrice, lastCompletedMax)
            
            newGrowth = confirmedMin > 0 ? ((confirmedMax - confirmedMin) / confirmedMin) * 100 : 0
            
            // Проверяем что новый рост достаточный для нового цикла
            if newGrowth >= minGrowthPercent
                log.info("✅ NEW CYCLE with SAME MIN has {0}% growth >= {1}% - FIBO_ACTIVE continues, searchStartBar={2}", newGrowth, minGrowthPercent, searchStartBar)
                forceRedraw := true  // Принудительная перерисовка нового Фибо
            else
                log.info("⚠️ NEW CYCLE with SAME MIN has only {0}% growth < {1}% - going to WAITING_GROWTH", newGrowth, minGrowthPercent)
                systemState := STATE_WAITING_GROWTH
        else
            // Нет SELL — но MAX обновился, значит нужно перезапустить торговый цикл
            // Но сначала проверяем - может этот Фибо уже полностью отторгован?
            isSameMinAsCompletedNoSell = not na(lastCompletedMin) and math.abs(confirmedMin - lastCompletedMin) < 0.0001
            isSameMaxAsCompletedNoSell = not na(lastCompletedMax) and math.abs(newMaxPrice - lastCompletedMax) < 0.0001
            isAlreadyCompletedNoSell = isSameMinAsCompletedNoSell and isSameMaxAsCompletedNoSell
            
            // DEBUG: Логируем все значения для диагностики
            log.info("🔍 PENDING CONFIRM DEBUG: confirmedMin={0}, lastCompletedMin={1}, newMax={2}, lastCompletedMax={3}", confirmedMin, lastCompletedMin, newMaxPrice, lastCompletedMax)
            log.info("🔍 PENDING CONFIRM DEBUG: isSameMin={0}, isSameMax={1}, isCompleted={2}", isSameMinAsCompletedNoSell, isSameMaxAsCompletedNoSell, isAlreadyCompletedNoSell)
            
            if isAlreadyCompletedNoSell
                // Этот Фибо уже полностью отторгован - НЕ сбрасываем на Stage 1
                log.warning("⛔ MAX UPDATE (no sell) BLOCKED: MIN={0}, MAX={1} already completed", confirmedMin, newMaxPrice)
            else
                // Не закрываем позиции — пусть strategy.exit() сработаеет на take-profit
                confirmedMax := newMaxPrice
                confirmedMaxBar := newMaxBar
                // Если MAX использует body, барьер = body
                if newMaxUsesBody
                    confirmedMaxRealHigh := newMaxPrice
                else
                    confirmedMaxRealHigh := high[bar_index - newMaxBar]
                maxUsesBody := newMaxUsesBody
                forceRedraw := true
                
                // Не сбрасываем positionXOpen чтобы отслеживать открытые позиции
                
                // ВАЖНО: Полный сброс торгового цикла при обновлении MAX
                sellCount := 0
                touchedZone06_07 := false
                doResetOrders := true
                
                // Сброс на Этап 1 при обновлении MAX
                tradingStage := 1
                orderLevel1 := 0.618
                orderLevel2 := 0.5
                orderLevel3 := 0.382
                sellLevel1 := 0.786
                sellLevel2 := 0.618
                sellLevel3 := 0.5
                cycleHadSell := false
                lastSoldMin := na
                lastSoldMax := na
                // Новый MAX — сбрасываем завершённый Фибо ТОЛЬКО если MAX реально новый (выше)
                if na(lastCompletedMax) or newMaxPrice > lastCompletedMax + 0.0001
                    lastCompletedMin := na
                    lastCompletedMax := na
                
                // Очищаем локальные MAX при обновлении MAX
                clearLocalMaxArrays()
                deleteLocalMaxLines()
                
                log.info("📈 MAX UPDATED (confirmed): newMax={0}, bar={1}, FULL CYCLE RESET to Stage 1", newMaxPrice, newMaxBar)

// ============================================================================
// РАСЧЕТ УРОВНЕЙ FIBONACCI
// ============================================================================

// ВАЖНО: Используем pendingMaxPrice для расчётов если есть pending MAX
// Это позволяет видеть актуальные уровни до подтверждения MAX
effectiveMax = hasPendingMax ? pendingMaxPrice : confirmedMax
effectiveMaxBar = hasPendingMax ? pendingMaxBar : confirmedMaxBar

fibRange = effectiveMax - confirmedMin
canBuildFibo = systemState == STATE_FIBO_ACTIVE and not na(confirmedMin) and not na(effectiveMax) and fibRange > 0

// Расчет уровней с учетом логарифмической шкалы
fib_1_000 = canBuildFibo ? effectiveMax : na
fib_0_786 = canBuildFibo ? getFibLevel(0.214, confirmedMin, effectiveMax, useLogScale) : na  // 78.6% уровень
fib_0_618 = canBuildFibo ? getFibLevel(0.382, confirmedMin, effectiveMax, useLogScale) : na
fib_0_500 = canBuildFibo ? getFibLevel(0.500, confirmedMin, effectiveMax, useLogScale) : na
fib_0_382 = canBuildFibo ? getFibLevel(0.618, confirmedMin, effectiveMax, useLogScale) : na
fib_0_236 = canBuildFibo ? getFibLevel(0.764, confirmedMin, effectiveMax, useLogScale) : na
fib_0_000 = canBuildFibo ? confirmedMin : na

getOrderPrice(level) =>
    canBuildFibo ? getFibLevel(1.0 - level, confirmedMin, effectiveMax, useLogScale) : na

order1Price = getOrderPrice(orderLevel1)
order2Price = getOrderPrice(orderLevel2)
order3Price = getOrderPrice(orderLevel3)
sell1Price = getOrderPrice(sellLevel1)
sell2Price = getOrderPrice(sellLevel2)
sell3Price = getOrderPrice(sellLevel3)

// ============================================================================
// ОТСЛЕЖИВАНИЕ КАСАНИЯ ЗОНЫ 0.6-0.7 (между MAX и 78.6%)
// ============================================================================

if canBuildFibo and not touchedZone06_07
    // Зона 0.6-0.7 это между MAX (100%) и уровнем 78.6%
    level_0786 = getFibLevel(0.214, confirmedMin, effectiveMax, useLogScale)  // 78.6% уровень
    // Если цена поднялась выше 78.6% — это зона перехая
    if high >= level_0786
        touchedZone06_07 := true
        log.info("🔒 touchedZone06_07 = true: цена достигла зоны 78.6%+ (high={0}, level_0786={1})", high, level_0786)

// ============================================================================
// ТОРГОВАЯ ЛОГИКА
// ============================================================================

// BUY срабатывает при касании уровня
touchOrder1 = canBuildFibo and not na(order1Price) and low <= order1Price
touchOrder2 = canBuildFibo and not na(order2Price) and low <= order2Price
touchOrder3 = canBuildFibo and not na(order3Price) and low <= order3Price

// Дебаг: логируем условия для BUY ордеров
if systemState == STATE_FIBO_ACTIVE and (low <= order1Price or low <= order2Price or low <= order3Price)
    log.info("📊 BUY CHECK bar={0}: low={1}, o2={2}", bar_index, low, order2Price)
    log.info("📊 Positions: pos1={0}, pos2={1}, pos3={2}", position1Open, position2Open, position3Open)
    // Дебаг: показываем какие уровни касаются
    touch1 = low <= order1Price
    touch2 = low <= order2Price
    touch3 = low <= order3Price
    log.info("📊 Touches: t1={0}, t2={1}, t3={2}, stage={3}", touch1, touch2, touch3, tradingStage)

// SELL срабатывает сразу при касании уровня (без ожидания закрытия бара)
touchSell1 = canBuildFibo and not na(sell1Price) and high >= sell1Price
touchSell2 = canBuildFibo and not na(sell2Price) and high >= sell2Price
touchSell3 = canBuildFibo and not na(sell3Price) and high >= sell3Price

var label buyLabel1 = na
var label buyLabel2 = na
var label buyLabel3 = na

// Формируем tooltip для BUY/SELL меток
// ВАЖНО: Используем effectiveMax для расчёта роста
currentGrowthPct = confirmedMin > 0 ? ((effectiveMax - confirmedMin) / confirmedMin) * 100 : 0
// Общая информация для tooltip BUY
stageText = tradingStage == 1 ? "Этап 1 (0.618/0.5/0.382)" : "Этап 2 (0.5/0.382/0.236)"
buyTooltip = "Этап: " + stageText +
     "\n───────────" +
     "\nMIN: " + str.tostring(nz(confirmedMin, 0), "#.####") + " (бар " + str.tostring(nz(confirmedMinBar, 0)) + ")" +
     "\nMAX: " + str.tostring(nz(effectiveMax, 0), "#.####") + " (бар " + str.tostring(nz(effectiveMaxBar, 0)) + ")" +
     (hasPendingMax ? " ⏳PENDING" : "") +
     "\nРост: " + str.tostring(currentGrowthPct, "#.#") + "%"

// ВАЖНО: Дополнительная проверка 100% роста перед открытием позиций
growthIsValid = currentGrowthPct >= minGrowthPercent

// Проверка что в этом цикле ещё не было SELL (запрет повторных покупок)
canBuyInCycle = not cycleHadSell

// Проверка что это НЕ тот же Фибо что уже был продан
// (MIN и MAX должны отличаться от последнего проданного цикла)
// ВАЖНО: На Этапе 2 это правило НЕ действует — покупаем на том же Фибо!
// ВАЖНО: Используем effectiveMax (который включает pending MAX)
isSameFiboAsSold = not na(lastSoldMin) and not na(lastSoldMax) and 
     math.abs(confirmedMin - lastSoldMin) < 0.0001 and math.abs(effectiveMax - lastSoldMax) < 0.0001

// Проверка что этот Фибо НЕ был полностью завершён (Этап 1 + Этап 2)
// Если цикл уже прошёл оба этапа — новые покупки запрещены до нового MIN или MAX
isCompletedFibo = not na(lastCompletedMin) and not na(lastCompletedMax) and 
     math.abs(confirmedMin - lastCompletedMin) < 0.0001 and math.abs(effectiveMax - lastCompletedMax) < 0.0001

// На Этапе 2 разрешаем покупать на том же Фибо (если он не завершён полностью)
isNewFibo = (tradingStage == 2 or not isSameFiboAsSold) and not isCompletedFibo

// Дебаг BUY2 - когда цена касается уровня 0.5 но позиция не открыта
if low <= order2Price and not position2Open and systemState == STATE_FIBO_ACTIVE and position1Open
    log.info("🔍 BUY2 DEBUG bar={0}: low={1}, order2Price={2}", bar_index, low, order2Price)
    log.info("🔍 BUY2 CONDITIONS: growthValid={0}, canBuyInCycle={1}, isNewFibo={2}, cycleHadSell={3}", growthIsValid, canBuyInCycle, isNewFibo, cycleHadSell)
    log.info("🔍 BUY2 FIBO: lastSoldMin={0}, lastSoldMax={1}, min={2}, effMax={3}", lastSoldMin, lastSoldMax, confirmedMin, effectiveMax)

// ============================================================================
// BUY ОРДЕРА: Рыночные ордера при касании уровня
// ============================================================================

// Для исторических баров: только одна покупка за бар (цена касается уровней последовательно)
// Для текущего бара (реальное время): можно несколько покупок
// BUY2 и BUY3 могут быть на том же баре что и предыдущий BUY
// На исторических барах - проверяем что позиция уже открыта (в текущем выполнении)
// На реальном времени - проверяем прошлый бар или текущий формирующийся
canBuy2OnThisBar = position1Open or not position1Open  // BUY2 можно если BUY1 уже открыт или не нужен
canBuy3OnThisBar = position2Open or not position2Open  // BUY3 можно если BUY2 уже открыт или не нужен

// ВАЖНО: Не покупаем на том же уровне где уже есть открытая позиция
// Это предотвращает дубли когда после обновления MAX уровни сдвигаются
priceThreshold = 0.0001  // Минимальная разница в цене
buy2NotSamePriceAsBuy1 = not position1Open or na(entryPrice1) or math.abs(order2Price - entryPrice1) > priceThreshold
buy3NotSamePriceAsBuy1 = not position1Open or na(entryPrice1) or math.abs(order3Price - entryPrice1) > priceThreshold
buy3NotSamePriceAsBuy2 = not position2Open or na(entryPrice2) or math.abs(order3Price - entryPrice2) > priceThreshold

// ВАЖНО: Торговля начинается только когда MAX подтверждён (нет PENDING MAX)
maxIsConfirmed = not hasPendingMax

// BUY1: Покупка при касании уровня 0.618
if touchOrder1 and not position1Open and systemState == STATE_FIBO_ACTIVE and growthIsValid and canBuyInCycle and isNewFibo and maxIsConfirmed
    // Strategy Tester: рыночный ордер на текущем баре (process_orders_on_close=true)
    strategy.entry("BUY1_" + str.tostring(currentCycleId), strategy.long, qty=orderAmount1/order1Price, comment="BUY1 $" + str.tostring(orderAmount1, "#"))
    // Стоп-лосс на уровне MIN (0%) - БЕЗ индивидуального TP!
    // TP будет через strategy.close_all() на динамическом уровне (зависит от кол-ва позиций)
    if enableStopLoss
        strategy.exit("SL_BUY1_" + str.tostring(currentCycleId), "BUY1_" + str.tostring(currentCycleId), stop=confirmedMin, comment="STOP-LOSS")
    if showLabels
        buyDate1 = str.format("{0,date,dd.MM.yyyy}", time)
        buyLevel1 = tradingStage == 1 ? "61.8%" : "50%"
        buyTooltip1 = "═══ BUY1 ═══" +
             "\nУровень: " + buyLevel1 +
             "\nЦена: " + str.tostring(nz(order1Price, 0), "#.########") +
             "\nСумма: $" + str.tostring(orderAmount1, "#") +
             "\nДата: " + buyDate1 +
             "\n───────────" +
             "\n" + buyTooltip
        buyLabel1 := label.new(bar_index, low, "", 
             color=color.green, 
             textcolor=color.white, 
             style=label.style_label_up, 
             size=size.small,
             tooltip=buyTooltip1)
    if not cycleHadBuy
        forceRedraw := true
    cycleHadBuy := true
    lastBuyBar := bar_index
    position1Open := true
    position1WasBought := true
    entryPrice1 := order1Price
    entryMin1 := confirmedMin
    entryMax1 := effectiveMax
    entryMinBar1 := confirmedMinBar
    entryMaxBar1 := effectiveMaxBar
    log.info("✅ BUY1: bar={0}, price={1}, cycleId={2}, stage={3}, pendingMax={4}", bar_index, order1Price, currentCycleId, tradingStage, hasPendingMax)
else if touchOrder1 and not position1Open and systemState == STATE_FIBO_ACTIVE and not maxIsConfirmed
    log.warning("⛔ BUY1 BLOCKED: MAX not confirmed (pending price={0})", pendingMaxPrice)
else if touchOrder1 and not position1Open and systemState == STATE_FIBO_ACTIVE and not growthIsValid
    log.warning("⛔ BUY1 BLOCKED: growth {0}% < {1}%", currentGrowthPct, minGrowthPercent)
else if touchOrder1 and not position1Open and systemState == STATE_FIBO_ACTIVE and not canBuyInCycle
    log.warning("⛔ BUY1 BLOCKED: cycleHadSell=true (stage={0})", tradingStage)
else if touchOrder1 and not position1Open and systemState == STATE_FIBO_ACTIVE and not isNewFibo
    if isCompletedFibo
        log.warning("⛔ BUY1 BLOCKED: isCompletedFibo (min={0}, max={1}, lastCompletedMin={2}, lastCompletedMax={3})", confirmedMin, effectiveMax, lastCompletedMin, lastCompletedMax)
    else
        log.warning("⛔ BUY1 BLOCKED: isSameFiboAsSold (min={0}, max={1}, lastSoldMin={2}, lastSoldMax={3})", confirmedMin, effectiveMax, lastSoldMin, lastSoldMax)

// BUY2: Покупка при касании уровня 0.5
if touchOrder2 and not position2Open and systemState == STATE_FIBO_ACTIVE and growthIsValid and canBuyInCycle and isNewFibo and canBuy2OnThisBar and buy2NotSamePriceAsBuy1 and maxIsConfirmed
    // Strategy Tester: рыночный ордер на текущем баре (process_orders_on_close=true)
    strategy.entry("BUY2_" + str.tostring(currentCycleId), strategy.long, qty=orderAmount2/order2Price, comment="BUY2 $" + str.tostring(orderAmount2, "#"))
    // Стоп-лосс на уровне MIN (0%) - БЕЗ индивидуального TP!
    // TP будет через strategy.close_all() на динамическом уровне (зависит от кол-ва позиций)
    if enableStopLoss
        strategy.exit("SL_BUY2_" + str.tostring(currentCycleId), "BUY2_" + str.tostring(currentCycleId), stop=confirmedMin, comment="STOP-LOSS")
    if showLabels
        buyDate2 = str.format("{0,date,dd.MM.yyyy}", time)
        buyLevel2 = tradingStage == 1 ? "50%" : "38.2%"
        buyTooltip2 = "═══ BUY2 ═══" +
             "\nУровень: " + buyLevel2 +
             "\nЦена: " + str.tostring(nz(order2Price, 0), "#.########") +
             "\nСумма: $" + str.tostring(orderAmount2, "#") +
             "\nДата: " + buyDate2 +
             "\n───────────" +
             "\n" + buyTooltip
        buyLabel2 := label.new(bar_index, low, "", 
             color=color.green, 
             textcolor=color.white, 
             style=label.style_label_up, 
             size=size.small,
             tooltip=buyTooltip2)
    if not cycleHadBuy
        forceRedraw := true
    cycleHadBuy := true
    lastBuyBar := bar_index
    position2Open := true
    position2WasBought := true
    entryPrice2 := order2Price
    entryMin2 := confirmedMin
    entryMax2 := effectiveMax
    entryMinBar2 := confirmedMinBar
    entryMaxBar2 := effectiveMaxBar
    log.info("✅ BUY2: bar={0}, price={1}, cycleId={2}", bar_index, order2Price, currentCycleId)
else if touchOrder2 and not position2Open and systemState == STATE_FIBO_ACTIVE and not growthIsValid
    log.warning("⛔ BUY2 BLOCKED: growth {0}% < {1}%", currentGrowthPct, minGrowthPercent)
else if touchOrder2 and not position2Open and systemState == STATE_FIBO_ACTIVE and not canBuyInCycle
    log.warning("⛔ BUY2 BLOCKED: cycleHadSell=true (stage={0})", tradingStage)
else if touchOrder2 and not position2Open and systemState == STATE_FIBO_ACTIVE and not isNewFibo
    log.warning("⛔ BUY2 BLOCKED: isSameFiboAsSold (min={0}, max={1}, lastSoldMin={2}, lastSoldMax={3})", confirmedMin, confirmedMax, lastSoldMin, lastSoldMax)

// BUY3: Покупка при касании уровня 0.382
if touchOrder3 and not position3Open and systemState == STATE_FIBO_ACTIVE and growthIsValid and canBuyInCycle and isNewFibo and canBuy3OnThisBar and buy3NotSamePriceAsBuy1 and buy3NotSamePriceAsBuy2 and maxIsConfirmed
    // Strategy Tester: рыночный ордер на текущем баре (process_orders_on_close=true)
    strategy.entry("BUY3_" + str.tostring(currentCycleId), strategy.long, qty=orderAmount3/order3Price, comment="BUY3 $" + str.tostring(orderAmount3, "#"))
    // Стоп-лосс на уровне MIN (0%) - БЕЗ индивидуального TP!
    // TP будет через strategy.close_all() на динамическом уровне (зависит от кол-ва позиций)
    if enableStopLoss
        strategy.exit("SL_BUY3_" + str.tostring(currentCycleId), "BUY3_" + str.tostring(currentCycleId), stop=confirmedMin, comment="STOP-LOSS")
    if showLabels
        buyDate3 = str.format("{0,date,dd.MM.yyyy}", time)
        buyLevel3 = tradingStage == 1 ? "38.2%" : "23.6%"
        buyTooltip3 = "═══ BUY3 ═══" +
             "\nУровень: " + buyLevel3 +
             "\nЦена: " + str.tostring(nz(order3Price, 0), "#.########") +
             "\nСумма: $" + str.tostring(orderAmount3, "#") +
             "\nДата: " + buyDate3 +
             "\n───────────" +
             "\n" + buyTooltip
        buyLabel3 := label.new(bar_index, low, "", 
             color=color.green, 
             textcolor=color.white, 
             style=label.style_label_up, 
             size=size.small,
             tooltip=buyTooltip3)
    if not cycleHadBuy
        forceRedraw := true
    cycleHadBuy := true
    lastBuyBar := bar_index
    position3Open := true
    position3WasBought := true
    entryPrice3 := order3Price
    entryMin3 := confirmedMin
    entryMax3 := effectiveMax
    entryMinBar3 := confirmedMinBar
    entryMaxBar3 := effectiveMaxBar
    log.info("✅ BUY3: bar={0}, price={1}, cycleId={2}", bar_index, order3Price, currentCycleId)
else if touchOrder3 and not position3Open and systemState == STATE_FIBO_ACTIVE and not growthIsValid
    log.warning("⛔ BUY3 BLOCKED: growth {0}% < {1}%", currentGrowthPct, minGrowthPercent)

var label sellLabel1 = na
var label sellLabel2 = na
var label sellLabel3 = na

// ═══════════════════════════════════════════════════════════════════════════
// ДИНАМИЧЕСКИЙ УРОВЕНЬ ПРОДАЖИ (зависит от количества открытых позиций)
// ═══════════════════════════════════════════════════════════════════════════
// Этап 1:
//   - Только BUY1 → SELL ALL @ 78.6% (sell1Price)
//   - BUY1 + BUY2 → SELL ALL @ 61.8% (sell2Price)
//   - BUY1 + BUY2 + BUY3 → SELL ALL @ 50% (sell3Price)
// Этап 2:
//   - Только BUY1 → SELL ALL @ 61.8%
//   - BUY1 + BUY2 → SELL ALL @ 50%
//   - BUY1 + BUY2 + BUY3 → SELL ALL @ 38.2%
// ═══════════════════════════════════════════════════════════════════════════

// Для исторических баров: SELL только если позиция была открыта на прошлом баре
// Для текущего бара (реальное время): можно на том же баре
// ВАЖНО: SELL разрешён минимум через 1 бар после последней покупки
barsSinceLastBuy = na(lastBuyBar) ? 999 : bar_index - lastBuyBar
canSellAfterBuy = barsSinceLastBuy >= 1
canSellPos1 = position1Open[1] or (position1Open and not barstate.isconfirmed)
canSellPos2 = position2Open[1] or (position2Open and not barstate.isconfirmed)
canSellPos3 = position3Open[1] or (position3Open and not barstate.isconfirmed)
hasAnyOpenPosition = (canSellPos1 or canSellPos2 or canSellPos3) and canSellAfterBuy

// Считаем количество открытых позиций
openPositionsCount = (position1Open ? 1 : 0) + (position2Open ? 1 : 0) + (position3Open ? 1 : 0)

// Вычисляем максимальную цену входа среди открытых позиций
// SELL должен быть только в плюс — цена продажи >= максимальной цены покупки
maxEntryPrice = 0.0
if position1Open and not na(entryPrice1)
    maxEntryPrice := math.max(maxEntryPrice, entryPrice1)
if position2Open and not na(entryPrice2)
    maxEntryPrice := math.max(maxEntryPrice, entryPrice2)
if position3Open and not na(entryPrice3)
    maxEntryPrice := math.max(maxEntryPrice, entryPrice3)

// Определяем ЕДИНСТВЕННЫЙ уровень продажи в зависимости от количества позиций
// ВАЖНО: Не проверяем все уровни! Только тот, который соответствует кол-ву позиций.
sellTriggered = false
sellPrice = 0.0
sellLevelName = ""

// Определяем целевой уровень продажи
targetSellPrice = na(sell1Price) ? na : sell1Price  // default
targetSellLevel = ""

if openPositionsCount == 1
    // Только BUY1 → SELL @ 78.6% (Этап 1) или 61.8% (Этап 2)
    targetSellPrice := sell1Price
    targetSellLevel := tradingStage == 1 ? "78.6%" : "61.8%"
else if openPositionsCount == 2
    // BUY1 + BUY2 → SELL @ 61.8% (Этап 1) или 50% (Этап 2)
    targetSellPrice := sell2Price
    targetSellLevel := tradingStage == 1 ? "61.8%" : "50%"
else if openPositionsCount >= 3
    // BUY1 + BUY2 + BUY3 → SELL @ 50% (Этап 1) или 38.2% (Этап 2)
    targetSellPrice := sell3Price
    targetSellLevel := tradingStage == 1 ? "50%" : "38.2%"

// Проверяем достижение целевого уровня
// ВАЖНО: SELL на уровне Fibo ВСЕГДА (даже в убыток)
// При 3 позициях: BUY1 будет в убытке, BUY2 примерно в 0, BUY3 в плюсе
// DEBUG: логируем состояние SELL проверки
if (position1Open or position2Open or position3Open) and high >= nz(targetSellPrice, 0)
    log.info("🔍 SELL CHECK: state={0}, hasOpen={1}, high={2}, target={3}, maxEntry={4}, stage={5}", 
         systemState, hasAnyOpenPosition, high, targetSellPrice, maxEntryPrice, tradingStage)
    log.info("🔍 SELL CONDITIONS: stateOK={0}, priceOK={1}", 
         systemState == STATE_FIBO_ACTIVE, high >= targetSellPrice)

if hasAnyOpenPosition and systemState == STATE_FIBO_ACTIVE and not na(targetSellPrice)
    touchTargetSell = high >= targetSellPrice
    if touchTargetSell  // Убрана проверка profitOK - продаём на уровне Fibo всегда
        sellTriggered := true
        sellPrice := targetSellPrice
        sellLevelName := targetSellLevel
        log.info("📈 SELL TRIGGERED: openPositions={0}, targetLevel={1}, targetPrice={2}, maxEntry={3}", openPositionsCount, targetSellLevel, targetSellPrice, maxEntryPrice)

// Если любой SELL сработал — закрываем ВСЕ позиции
if sellTriggered
    // Считаем профит от каждой открытой позиции
    totalAmount = 0.0
    totalProfit = 0.0
    
    profit1_val = 0.0
    profitPct1_val = 0.0
    profit2_val = 0.0
    profitPct2_val = 0.0
    profit3_val = 0.0
    profitPct3_val = 0.0
    
    // Флаги для отслеживания какие позиции были проданы (для tooltip)
    sold1 = false
    sold2 = false
    sold3 = false
    
    if position1Open
        profit1_val := ((sellPrice - entryPrice1) / entryPrice1) * orderAmount1
        profitPct1_val := ((sellPrice - entryPrice1) / entryPrice1) * 100
        totalAmount := totalAmount + orderAmount1
        totalProfit := totalProfit + profit1_val
        position1Open := false
        sold1 := true
    
    if position2Open
        profit2_val := ((sellPrice - entryPrice2) / entryPrice2) * orderAmount2
        profitPct2_val := ((sellPrice - entryPrice2) / entryPrice2) * 100
        totalAmount := totalAmount + orderAmount2
        totalProfit := totalProfit + profit2_val
        position2Open := false
        sold2 := true
    
    if position3Open
        profit3_val := ((sellPrice - entryPrice3) / entryPrice3) * orderAmount3
        profitPct3_val := ((sellPrice - entryPrice3) / entryPrice3) * 100
        totalAmount := totalAmount + orderAmount3
        totalProfit := totalProfit + profit3_val
        position3Open := false
        sold3 := true
    
    totalProfitPct = totalAmount > 0 ? (totalProfit / totalAmount) * 100 : 0
    
    // Strategy Tester: закрываем ВСЕ позиции
    strategy.close_all(comment="SELL ALL @ " + sellLevelName)
    
    if showLabels
        sellText = showProfitPercent ? str.tostring(totalProfitPct, "#.#") + "%" : ""
        sellDate = str.format("{0,date,dd.MM.yyyy}", time)
        // Детализация профита по каждой позиции (показываем если позиция была продана)
        detailProfit = ""
        if sold1
            detailProfit := detailProfit + "BUY1 $" + str.tostring(orderAmount1, "#") + ": " + (profit1_val >= 0 ? "+" : "") + str.tostring(profitPct1_val, "#.#") + "%"
        if sold2
            detailProfit := detailProfit + (str.length(detailProfit) > 0 ? "\n" : "") + "BUY2 $" + str.tostring(orderAmount2, "#") + ": " + (profit2_val >= 0 ? "+" : "") + str.tostring(profitPct2_val, "#.#") + "%"
        if sold3
            detailProfit := detailProfit + (str.length(detailProfit) > 0 ? "\n" : "") + "BUY3 $" + str.tostring(orderAmount3, "#") + ": " + (profit3_val >= 0 ? "+" : "") + str.tostring(profitPct3_val, "#.#") + "%"
        
        sellTooltip = "SELL ALL @ " + str.tostring(nz(sellPrice, 0), "#.####") + " (" + sellLevelName + ")" +
             "\nДата: " + sellDate +
             "\n───────────" +
             "\n" + detailProfit +
             "\n───────────" +
             "\nИтого: " + (totalProfit >= 0 ? "+" : "") + "$" + str.tostring(totalProfit, "#.##")
        sellLabel1 := label.new(bar_index, high, sellText, 
             color=color.red, 
             textcolor=color.white, 
             style=label.style_label_down, 
             size=size.small,
             tooltip=sellTooltip)
    
    sellCount := sellCount + 1
    cycleHadSell := true  // Запрещаем повторные покупки в этом цикле
    lastSoldMin := confirmedMin  // Запоминаем MIN/MAX проданного цикла
    // ВАЖНО: Сохраняем ПОДТВЕРЖДЁННЫЙ MAX, а не effectiveMax (который может включать pending)
    lastSoldMax := confirmedMax
    log.info("✅ SELL ALL @ {0}: bar={1}, price={2}, amount=${3}, profit=${4}, lastSoldMax={5}", sellLevelName, bar_index, sellPrice, totalAmount, totalProfit, lastSoldMax)
    
    // ═══ ПЕРЕХОД МЕЖДУ ЭТАПАМИ ═══
    // ВАЖНО: Этап 2 только если была ТОЛЬКО BUY1 (без BUY2/BUY3)
    // Если были BUY2 или BUY3 — цикл полностью завершается
    hadOnlyBuy1 = not position2WasBought and not position3WasBought
    log.info("🔍 STAGE CHECK: hadOnlyBuy1={0}, position2WasBought={1}, position3WasBought={2}, tradingStage={3}", 
         hadOnlyBuy1, position2WasBought, position3WasBought, tradingStage)
    
    if tradingStage == 1 and hadOnlyBuy1
        // После первого SELL с только BUY1 — сдвигаем уровни вниз для Этапа 2
        tradingStage := 2
        // Новые уровни BUY для Этапа 2
        orderLevel1 := 0.5      // было 0.618
        orderLevel2 := 0.382    // было 0.5
        orderLevel3 := 0.236    // было 0.382
        // Новые уровни SELL для Этапа 2
        sellLevel1 := 0.618     // было 0.786
        sellLevel2 := 0.5       // было 0.618
        sellLevel3 := 0.382     // было 0.5
        // Разрешаем новые покупки на Этапе 2
        cycleHadSell := false
        // Сбрасываем флаги позиций для новых покупок
        position1Open := false
        position2Open := false
        position3Open := false
        position1WasBought := false
        position2WasBought := false
        position3WasBought := false
        log.info("🔄 ПЕРЕХОД НА ЭТАП 2: новые уровни BUY(0.5/0.382/0.236), SELL(0.618/0.5/0.382)")
    else if tradingStage == 2 or (tradingStage == 1 and not hadOnlyBuy1)
        // После SELL на Этапе 2 ИЛИ после SELL с BUY2/BUY3 на Этапе 1 — цикл полностью завершён
        if tradingStage == 1
            log.info("🏁 ЦИКЛ ЗАВЕРШЁН (Этап 1 с BUY2/BUY3): без Этапа 2, переход в WAITING_RESET")
        // Отменяем все неисполненные лимитные ордера текущего цикла
        strategy.cancel("BUY1_" + str.tostring(currentCycleId))
        strategy.cancel("BUY2_" + str.tostring(currentCycleId))
        strategy.cancel("BUY3_" + str.tostring(currentCycleId))
        prevConfirmedMin := confirmedMin
        prevConfirmedMax := confirmedMax
        prevConfirmedMinBar := confirmedMinBar
        prevConfirmedMaxBar := confirmedMaxBar
        searchStartBar := bar_index
        maxSearchStartBar := bar_index  // MAX ищем ТОЛЬКО после SELL!
        // ВАЖНО: Сохраняем MIN/MAX как полностью завершённый цикл
        // Это предотвратит новый цикл с теми же MIN/MAX
        lastCompletedMin := confirmedMin
        lastCompletedMax := effectiveMax
        // Сбрасываем lastSoldMin/Max — цикл завершён полностью
        lastSoldMin := na
        lastSoldMax := na
        systemState := STATE_WAITING_RESET
        log.info("🏁 ЦИКЛ ЗАВЕРШЁН (Этап {0}): переход в WAITING_RESET, lastCompletedMin={1}, lastCompletedMax={2}", tradingStage, lastCompletedMin, lastCompletedMax)
    
    // Обновляем статистику по индикатору
    if na(firstTradeTime)
        firstTradeTime := time
    totalTrades := totalTrades + 1
    totalProfitLoss := totalProfitLoss + totalProfit
    currentEquity := currentEquity + totalProfit
    if totalProfit > 0
        grossProfit := grossProfit + totalProfit
        profitableTrades := profitableTrades + 1
    else
        grossLoss := grossLoss + math.abs(totalProfit)
    if currentEquity > maxEquity
        maxEquity := currentEquity
    drawdown = maxEquity - currentEquity
    if drawdown > maxDrawdown
        maxDrawdown := drawdown

// ============================================================================
// СТОП-ЛОСС НА УРОВНЕ 0 (МИНИМУМ)
// ============================================================================

// Exit ордера уже настроены при входе в позицию с limit (take-profit) и stop (stop-loss)
// Отмена не нужна — ордера автоматически отменяются при закрытии позиции

touchLevel0 = canBuildFibo and not na(fib_0_000) and low <= fib_0_000 and barstate.isconfirmed

if enableStopLoss and touchLevel0 and (position1Open or position2Open or position3Open) and systemState == STATE_FIBO_ACTIVE
    totalLoss = 0.0
    totalAmount = 0.0
    
    if position1Open
        loss1 = ((fib_0_000 - entryPrice1) / entryPrice1) * orderAmount1
        totalLoss := totalLoss + loss1
        totalAmount := totalAmount + orderAmount1
        position1Open := false
    
    if position2Open
        loss2 = ((fib_0_000 - entryPrice2) / entryPrice2) * orderAmount2
        totalLoss := totalLoss + loss2
        totalAmount := totalAmount + orderAmount2
        position2Open := false
    
    if position3Open
        loss3 = ((fib_0_000 - entryPrice3) / entryPrice3) * orderAmount3
        totalLoss := totalLoss + loss3
        totalAmount := totalAmount + orderAmount3
        position3Open := false
    
    // Strategy Tester: закрываем ВСЕ позиции по стоп-лоссу
    strategy.close_all(comment="STOP-LOSS @ MIN")
    
    if showLabels
        label.new(bar_index, low, "STOP-LOSS\n$" + str.tostring(totalAmount, "#") + "\n" + str.tostring(totalLoss, "#.##"), 
             color=color.new(color.maroon, 0), 
             textcolor=color.white, 
             style=label.style_label_up, 
             size=size.small)
    
    log.info("⛔ STOP-LOSS! Starting fresh search for new MIN")
    
    // Обновляем статистику по индикатору (убыток отрицательный)
    if na(firstTradeTime)
        firstTradeTime := time
    totalTrades := totalTrades + 1
    totalProfitLoss := totalProfitLoss + totalLoss  // totalLoss уже отрицательный
    currentEquity := currentEquity + totalLoss
    grossLoss := grossLoss + math.abs(totalLoss)
    if currentEquity > maxEquity
        maxEquity := currentEquity
    drawdown = maxEquity - currentEquity
    if drawdown > maxDrawdown
        maxDrawdown := drawdown
    
    currentCycleId := currentCycleId + 1
    
    // Отменяем все неисполненные лимитные ордера предыдущего цикла
    strategy.cancel("BUY1_" + str.tostring(currentCycleId - 1))
    strategy.cancel("BUY2_" + str.tostring(currentCycleId - 1))
    strategy.cancel("BUY3_" + str.tostring(currentCycleId - 1))
    
    // НЕ удаляем Fibo элементы - оставляем как историю
    // Только сбрасываем переменные для нового цикла
    box_1_000 := na
    box_0_786 := na
    box_0_618 := na
    box_0_500 := na
    box_0_382 := na
    box_0_236 := na
    label_fib_1_000 := na
    label_fib_0_618 := na
    label_fib_0_500 := na
    label_fib_0_382 := na
    label_fib_0_236 := na
    label_min := na
    label_max := na
    fiboWasDrawn := false
    drawnCycleId := -1
    drawnMaxBar := na
    
    // Сохраняем текущие значения как prev для проверки правил нового MIN
    prevConfirmedMin := confirmedMin
    prevConfirmedMax := confirmedMax
    prevConfirmedMinBar := confirmedMinBar
    prevConfirmedMaxBar := confirmedMaxBar
    
    // НЕ сбрасываем confirmedMin/Max - они нужны для "Проверки 2" (перехай)
    // confirmedMin := na  // ОСТАВЛЯЕМ для проверки перехая
    // confirmedMinBar := na
    // confirmedMax := na  // ОСТАВЛЯЕМ для проверки перехая  
    // confirmedMaxBar := na
    
    searchStartBar := bar_index
    maxSearchStartBar := bar_index  // MAX ищем ТОЛЬКО после SELL!
    systemState := STATE_WAITING_RESET  // Идём в WAITING_RESET
    sellCount := 0
    touchedZone06_07 := false
    doResetOrders := true

// ============================================================================
// ОЖИДАНИЕ НОВОГО МИНИМУМА/МАКСИМУМА ПОСЛЕ RESET
// ============================================================================

// В STATE_WAITING_RESET проверяем: есть ли НОВЫЙ локальный минимум с 100%+ ростом?
// После 10 баров после SELL - ищем любой минимум с 100%+ ростом (независимо от старого)
// Ограничиваем поиск барами после листинга
waitingResetBarsAfterListing = isAfterListingPeriod and not na(firstBarAfterListing) ? bar_index - firstBarAfterListing + 1 : 0
waitingResetLookbackRaw = na(searchStartBar) ? waitingResetBarsAfterListing : bar_index - searchStartBar + 1
waitingResetLookback = math.max(1, math.min(math.min(math.min(lookbackPeriod, bar_index + 1), waitingResetLookbackRaw), waitingResetBarsAfterListing))
barsAfterSell = na(searchStartBar) ? 0 : bar_index - searchStartBar
waitingResetLocalMin = waitingResetLookback >= 1 ? ta.lowest(low, waitingResetLookback) : low
// Выносим ta.lowestbars из тернарного оператора для согласованности
waitingResetLocalMinBarCalc = ta.lowestbars(low, waitingResetLookback)
waitingResetLocalMinBar = waitingResetLookback >= 1 ? waitingResetLocalMinBarCalc : 0
// Локальный MAX в рамках того же периода (для проверки isCase2)
waitingResetLocalMax = waitingResetLookback >= 1 ? ta.highest(high, waitingResetLookback) : high
waitingResetGrowth = waitingResetLocalMin > 0 ? ((waitingResetLocalMax - waitingResetLocalMin) / waitingResetLocalMin) * 100 : 0

// ЛОГ только на последних 50 барах чтобы не переполнить лимит Pine (max ~500 логов)
isRecentBar = bar_index >= (last_bar_index - 50)
if isRecentBar
    log.info("BAR #{0}: state={1}, searchStartBar={2}, confirmedMin={3}", 
         bar_index, systemState, na(searchStartBar) ? -1 : searchStartBar, na(confirmedMin) ? 0.0 : confirmedMin)
    if systemState == STATE_WAITING_GROWTH
        log.info("🔍 WAITING_GROWTH: maxGrowth={0}%, currentGrowth={1}%, maxPrice={2}, minPrice={3}, prevMin={4}", 
             maxGrowthAfterMin, currentGrowth, maxPriceAfterMin, confirmedMin, na(prevConfirmedMin) ? 0.0 : prevConfirmedMin)

// DEBUG: логгируем в WAITING_RESET только на последних 50 барах
if systemState == STATE_WAITING_RESET and isRecentBar
    log.info("🔍 WAITING_RESET DEBUG: searchStartBar={0}, bar_index={1}, lookback={2}", 
         na(searchStartBar) ? -1 : searchStartBar, bar_index, waitingResetLookback)
    log.info("🔍 WAITING_RESET DEBUG: localMin={0}, localMinBar={1}, growth={2}%", 
         waitingResetLocalMin, waitingResetLocalMinBar, waitingResetGrowth)
    log.info("🔍 WAITING_RESET DEBUG: confirmedMin={0}, confirmedMax={1}, low={2}, high={3}", 
         na(confirmedMin) ? 0.0 : confirmedMin, na(confirmedMax) ? 0.0 : confirmedMax, low, high)
    
    // DEBUG: проверяем условия для Проверки 3
    cond3_growth = waitingResetGrowth >= 100
    cond3_notna = not na(waitingResetLocalMin)
    cond3_above = na(confirmedMin) ? false : waitingResetLocalMin > confirmedMin * 0.98
    log.info("🔍 CHECK3 CONDITIONS: growth>=100={0}, notNa={1}, aboveMin*0.98={2}, minThreshold={3}", 
         cond3_growth ? 1 : 0, cond3_notna ? 1 : 0, cond3_above ? 1 : 0, 
         na(confirmedMin) ? 0.0 : confirmedMin * 0.98)

if systemState == STATE_WAITING_RESET
    // Проверка на открытые позиции для FULL RESET
    hasOpenPositionsWR = position1Open or position2Open or position3Open
    canDoFullResetWR = not hasOpenPositionsWR or enableStopLoss
    
    // Проверка 1: Падение ниже MIN * 0.98 → полный reset (только если нет открытых позиций или стоп-лосс включён)
    if low < confirmedMin * 0.98 and canDoFullResetWR
        log.info("📉 FULL RESET: low={0} < min*0.98={1}, starting new search", low, confirmedMin * 0.98)
        currentCycleId := currentCycleId + 1
        confirmedMin := na
        confirmedMinBar := na
        confirmedMax := na
        confirmedMaxBar := na
        // Сбрасываем prev значения — ищем любой новый MIN
        prevConfirmedMin := na
        prevConfirmedMax := na
        prevConfirmedMinBar := na
        prevConfirmedMaxBar := na
        // Сбрасываем lastSold — новый MIN/MAX будут другими
        lastSoldMin := na
        lastSoldMax := na
        // Новый цикл — сбрасываем завершённый Фибо
        lastCompletedMin := na
        lastCompletedMax := na
        searchStartBar := bar_index  // Начинаем поиск с текущего бара
        maxSearchStartBar := bar_index  // MAX тоже ищем с текущего бара
        systemState := STATE_SEARCHING_MIN
        sellCount := 0
        touchedZone06_07 := false
        position1Open := false
        position2Open := false
        position3Open := false
        doResetOrders := true
        
        // Удаляем старые Fibo элементы с графика (только если не сохраняем историю)
        if not showAllFiboHistory
            box.delete(box_1_000)
            box.delete(box_0_786)
            box.delete(box_0_618)
            box.delete(box_0_500)
            box.delete(box_0_382)
            box.delete(box_0_236)
            label.delete(label_fib_1_000)
            label.delete(label_fib_0_618)
            label.delete(label_fib_0_500)
            label.delete(label_fib_0_382)
            label.delete(label_fib_0_236)
            label.delete(label_min)
            label.delete(label_max)
        
        box_1_000 := na
        box_0_786 := na
        box_0_618 := na
        box_0_500 := na
        box_0_382 := na
        box_0_236 := na
        label_fib_1_000 := na
        label_fib_0_618 := na
        label_fib_0_500 := na
        label_fib_0_382 := na
        label_fib_0_236 := na
        label_min := na
        label_max := na
        fiboWasDrawn := false
        drawnCycleId := -1
        drawnMaxBar := na
    
    // FULL RESET заблокирован - есть открытые позиции и стоп-лосс выключен
    else if low < confirmedMin * 0.98 and not canDoFullResetWR
        log.info("⚠️ FULL RESET BLOCKED (WAITING_RESET): low={0} < min*0.98={1}, but positions open and stopLoss disabled", low, confirmedMin * 0.98)
    
    // Проверка 2: Перехай → новый цикл с тем же MIN
    else if high > confirmedMax
        currentCycleId := currentCycleId + 1
        log.info("🔄 NEW CYCLE in WAITING_RESET: cycleId={0}, high={1} > max={2}, SAME MIN={3}", 
             currentCycleId, high, confirmedMax, confirmedMin)
        
        // Удаляем старые Fibo элементы с графика (только если не сохраняем историю)
        if not showAllFiboHistory
            box.delete(box_1_000)
            box.delete(box_0_786)
            box.delete(box_0_618)
            box.delete(box_0_500)
            box.delete(box_0_382)
            box.delete(box_0_236)
            label.delete(label_fib_1_000)
            label.delete(label_fib_0_618)
            label.delete(label_fib_0_500)
            label.delete(label_fib_0_382)
            label.delete(label_fib_0_236)
            label.delete(label_min)
            label.delete(label_max)
        
        box_1_000 := na
        box_0_786 := na
        box_0_618 := na
        box_0_500 := na
        box_0_382 := na
        box_0_236 := na
        label_fib_1_000 := na
        label_fib_0_618 := na
        label_fib_0_500 := na
        label_fib_0_382 := na
        label_fib_0_236 := na
        label_min := na
        label_max := na
        fiboWasDrawn := false
        drawnCycleId := -1
        drawnMaxBar := na
        
        // Проверяем был ли новый минимум с момента SELL
        // ДВА УСЛОВИЯ для нового MIN:
        // Условие 1: Новый MIN ниже текущего MIN
        // Условие 2: Новый MIN выше текущего MIN, НО новый MAX ниже старого MAX (при росте 100%)
        newLowerMinFound = false
        newLowerMinPrice = confirmedMin
        newLowerMinBar = confirmedMinBar
        newLowerMinUsesBody = minUsesBody
        
        // Сохраняем старый MAX для проверки Условия 2 (до обновления на high)
        oldMaxWR = confirmedMax
        newMaxWR = high  // Новый MAX = текущий high (перехай)
        
        // Ищем минимум с момента SELL (searchStartBar) до текущего бара
        barsToSearchMin = na(searchStartBar) ? 0 : bar_index - searchStartBar + 1
        if barsToSearchMin > 0
            for i = 0 to math.min(barsToSearchMin - 1, 100)
                candidateMinPriceWR = low[i]
                candidateMinWickWR = getLowerWickPercent(i)
                if candidateMinWickWR > wickThreshold
                    candidateMinPriceWR := math.min(open[i], close[i])
                
                // Условие 1: MIN ниже текущего
                isCond1WR = candidateMinPriceWR < confirmedMin
                
                // Условие 2: MIN выше текущего, но новый MAX ниже старого MAX + рост 100%
                growthWR = candidateMinPriceWR > 0 ? ((newMaxWR - candidateMinPriceWR) / candidateMinPriceWR) * 100 : 0
                isCond2WR = candidateMinPriceWR > confirmedMin and newMaxWR < oldMaxWR and growthWR >= minGrowthPercent
                
                if isCond1WR
                    // Только если MIN действительно ниже
                    if candidateMinWickWR <= wickThreshold
                        newLowerMinPrice := low[i]
                        newLowerMinBar := bar_index - i
                        newLowerMinUsesBody := false
                        newLowerMinFound := true
                    else
                        bodyMinWR = math.min(open[i], close[i])
                        if bodyMinWR < newLowerMinPrice
                            newLowerMinPrice := bodyMinWR
                            newLowerMinBar := bar_index - i
                            newLowerMinUsesBody := true
                            newLowerMinFound := true
        
        if newLowerMinFound
            log.info("📍 FOUND LOWER MIN since SELL: price={0}, bar={1} (was {2})", newLowerMinPrice, newLowerMinBar, confirmedMin)
            confirmedMin := newLowerMinPrice
            confirmedMinBar := newLowerMinBar
            minUsesBody := newLowerMinUsesBody
        else
            log.info("📍 KEEPING SAME MIN in WAITING_RESET (no lower found): minPrice={0}, minBar={1}", confirmedMin, confirmedMinBar)
        
        upperWick = getUpperWickPercent(0, confirmedMin)
        newMaxPrice = high
        newMaxBar = bar_index
        newMaxUsesBody = false
        
        // ВАЖНО: Ищем MAX от confirmedMinBar (не от confirmedMaxBar!)
        // Это гарантирует что мы найдём наивысший MAX во всём диапазоне от MIN
        barsToSearchMax = bar_index - confirmedMinBar
        bestHighPriceMax = 0.0
        bestHighBarMax = bar_index
        foundGoodCandleMax = false
        
        // Проверяем текущий бар (перехай) первым
        if upperWick <= wickThreshold
            bestHighPriceMax := high
            bestHighBarMax := bar_index
            foundGoodCandleMax := true
        
        // Ищем в истории бары с маленькой тенью
        for i = 1 to barsToSearchMax
            checkWick = getUpperWickPercent(i, confirmedMin)
            if checkWick <= wickThreshold and high[i] > bestHighPriceMax
                bestHighPriceMax := high[i]
                bestHighBarMax := bar_index - i
                foundGoodCandleMax := true
        
        // ВАЖНО: Если найденный MAX ниже текущего high - это значит текущий бар имеет
        // большую тень, но является АБСОЛЮТНЫМ перехаем. Используем текущий бар!
        currentBarBody = math.max(open, close)
        if foundGoodCandleMax and bestHighPriceMax < high
            // Текущий бар - абсолютный перехай с большой тенью
            // Используем high текущего бара (реальный перехай), НЕ ищем соседа с меньшим high
            if upperWick <= wickThreshold
                // Тень OK - используем high
                newMaxPrice := high
                newMaxBar := bar_index
                log.info("🔍 WAITING_RESET: Current bar is absolute high with OK wick: {0}", high)
            else
                // Тень большая - используем тело текущего бара (это реальный перехай!)
                newMaxPrice := currentBarBody
                newMaxBar := bar_index
                newMaxUsesBody := true
                log.info("🔍 WAITING_RESET: Current bar is absolute high with big wick, using body: {0}", currentBarBody)
        else if foundGoodCandleMax
            newMaxPrice := bestHighPriceMax
            newMaxBar := bestHighBarMax
            log.info("🔍 WAITING_RESET: Found best MAX: bar={0}, price={1}", bestHighBarMax, bestHighPriceMax)
        else
            maxHighPriceWR = high
            maxHighBarWR = 0
            problemCandleBodyWR = math.max(open[0], close[0])
            
            for i = 1 to barsToSearchMax
                if high[i] > maxHighPriceWR
                    maxHighPriceWR := high[i]
                    maxHighBarWR := i
            
            foundNeighborWR = false
            for i = 1 to 5
                if i <= barsToSearchMax
                    neighborWickWR = getUpperWickPercent(i, confirmedMin)
                    if neighborWickWR <= wickThreshold and high[i] > problemCandleBodyWR
                        newMaxPrice := high[i]
                        newMaxBar := bar_index - i
                        foundNeighborWR := true
                        log.info("🔍 WAITING_RESET: Found neighbor with wick > body: bar-{0}, price={1}", i, high[i])
                        break
            
            if not foundNeighborWR
                newMaxPrice := problemCandleBodyWR
                newMaxBar := bar_index
                newMaxUsesBody := true
                log.info("⚠️ WAITING_RESET: Using current body: {0}", problemCandleBodyWR)
        
        // ВАЖНО: MAX должен быть PENDING, не CONFIRMED!
        // Нужно дождаться касания 0.618 для подтверждения
        pendingMaxPrice := newMaxPrice
        pendingMaxBar := newMaxBar
        pendingMaxUsesBody := newMaxUsesBody
        hasPendingMax := true
        confirmedMax := na  // НЕ confirmed!
        confirmedMaxBar := na
        
        // Сохраняем значение для сравнения при следующем перехае
        // ВАЖНО: Если MAX использует body (большой фитиль), барьером тоже должен быть body
        // Это позволяет PENDING MAX обновляться при появлении баров с high > body
        // Финальный MAX определится когда цена коснётся 0.618
        if newMaxUsesBody
            confirmedMaxRealHigh := newMaxPrice  // body = барьер
        else
            confirmedMaxRealHigh := newMaxBar == bar_index ? high : high[bar_index - newMaxBar]
        maxUsesBody := newMaxUsesBody
        
        // Рост считаем от pendingMaxPrice (effectiveMax)
        newGrowth = confirmedMin > 0 ? ((pendingMaxPrice - confirmedMin) / confirmedMin) * 100 : 0
        
        // Расчёт уровня 0.618 для подтверждения
        expectedFib618WR = confirmedMin + (newMaxPrice - confirmedMin) * 0.618
        log.info("════════════════════════════════════════════════════════════")
        log.info("📊 [MAX EVENT] TYPE: WAITING_RESET ПЕРЕХАЙ - NEW PENDING MAX")
        log.info("📊 [MAX EVENT] REASON: high={0} > old confirmedMax={1}", high, oldMaxWR)
        log.info("📊 [MAX EVENT] PENDING MAX: {0} at bar {1}", newMaxPrice, newMaxBar)
        log.info("📊 [MAX EVENT] MIN: {0} at bar {1}", confirmedMin, confirmedMinBar)
        log.info("📊 [MAX EVENT] Uses body: {0}, Barrier: {1}", newMaxUsesBody, confirmedMaxRealHigh)
        log.info("📊 [MAX EVENT] Growth from MIN: {0}%", newGrowth)
        log.info("📊 [MAX EVENT] Level 0.618 for confirmation: {0}", expectedFib618WR)
        log.info("📊 [MAX EVENT] STATUS: Waiting for price to touch 0.618 level")
        log.info("════════════════════════════════════════════════════════════")
        
        // Проверяем что рост >= 100%
        if newGrowth >= minGrowthPercent
            sellCount := 0
            touchedZone06_07 := false
            position1Open := false
            position2Open := false
            position3Open := false
            doResetOrders := true
            prevConfirmedMax := na
            prevConfirmedMin := na
            prevConfirmedMaxBar := na
            prevConfirmedMinBar := na
            // ВАЖНО: Сбрасываем lastSoldMin/Max — это НОВЫЙ цикл с новым Фибо
            lastSoldMin := na
            lastSoldMax := na
            // Новый MAX — сбрасываем завершённый Фибо
            lastCompletedMin := na
            lastCompletedMax := na
            // При SAME MIN разрешаем использовать старый MIN - сдвигаем searchStartBar
            searchStartBar := confirmedMinBar
            
            // ВАЖНО: Сброс на Этап 1 при новом цикле!
            tradingStage := 1
            orderLevel1 := 0.618
            orderLevel2 := 0.5
            orderLevel3 := 0.382
            sellLevel1 := 0.786
            sellLevel2 := 0.618
            sellLevel3 := 0.5
            cycleHadSell := false
            
            log.info("⏳ WAITING_RESET->FIBO with SAME MIN: {0}% growth - OK, PENDING MAX={1}, waiting for 0.618 touch", newGrowth, pendingMaxPrice)
            systemState := STATE_FIBO_ACTIVE
            forceRedraw := true  // Принудительная перерисовка нового Фибо
        else
            // Рост недостаточный, ищем новый MIN
            log.info("⚠️ WAITING_RESET: growth {0}% < {1}%, need new MIN", newGrowth, minGrowthPercent)
            confirmedMin := na
            confirmedMinBar := na
            confirmedMax := na
            confirmedMaxBar := na
            searchStartBar := bar_index
            maxSearchStartBar := bar_index  // MAX тоже ищем с текущего бара
            systemState := STATE_SEARCHING_MIN
    
    // Проверка 3: После 10 баров - новый минимум с 100%+ ростом → новый цикл
    // ВАЖНО: Не начинать новый цикл пока есть открытые позиции!
    // 
    // ТРИ СЛУЧАЯ для нового MIN:
    // Случай 1: Новый MIN НИЖЕ предыдущего MIN → классический 100% рост
    // Случай 2: Новый MIN ВЫШЕ предыдущего MIN, но новый MAX НИЖЕ предыдущего MAX → 100% рост внутри старого диапазона (используем СТАРЫЙ MIN)
    // Случай 3: После завершённого цикла - новый MIN ВЫШЕ lastCompletedMin, MAX НИЖЕ lastCompletedMax → НОВЫЙ цикл с НОВЫМ MIN/MAX
    else if barsAfterSell >= 10 and waitingResetGrowth >= 100 and not na(waitingResetLocalMin) and not position1Open and not position2Open and not position3Open
        // Прошло 10+ баров после SELL, есть минимум с ростом 100%+
        
        // Находим бар этого минимума (ta.lowestbars возвращает отрицательное смещение)
        newMinBarOffset = math.abs(nz(waitingResetLocalMinBar, 0))
        newMinBarAbsolute = bar_index - newMinBarOffset
        
        // Проверяем условия для нового цикла
        // Случай 1: Новый MIN ниже предыдущего MIN (или первый раз - prevConfirmedMin = na)
        // ВАЖНО: если prevConfirmedMin = na, это НЕ значит что можно брать любой MIN!
        // Это значит что нужно проверять по prevConfirmedMax (если он есть)
        isCase1 = not na(prevConfirmedMin) and waitingResetLocalMin < prevConfirmedMin
        
        // Случай 2: Новый MIN выше предыдущего MIN, но локальный MAX ниже предыдущего MAX
        // Используем waitingResetLocalMax (максимум в рамках периода поиска)
        isCase2 = not na(prevConfirmedMin) and not na(prevConfirmedMax) and 
             waitingResetLocalMin > prevConfirmedMin and waitingResetLocalMax < prevConfirmedMax
        
        // Случай 3 (НОВЫЙ): После завершённого цикла появился НОВЫЙ Фибо внутри старого диапазона
        // Новый MIN выше lastCompletedMin, новый MAX ниже lastCompletedMax, рост 100%+ от НОВОГО MIN
        // Это позволяет торговать внутренние движения после завершения полного цикла
        growthFromNewMin = waitingResetLocalMin > 0 ? ((waitingResetLocalMax - waitingResetLocalMin) / waitingResetLocalMin) * 100 : 0
        isCase3 = not na(lastCompletedMin) and not na(lastCompletedMax) and 
             waitingResetLocalMin > lastCompletedMin and waitingResetLocalMax < lastCompletedMax and
             growthFromNewMin >= minGrowthPercent
        
        // Особый случай: первый цикл после листинга (нет prev значений)
        isFirstCycle = na(prevConfirmedMin) and na(prevConfirmedMax)
        
        canStartNewCycle = isCase1 or isCase2 or isCase3 or isFirstCycle
        
        log.info("🔍 CHECK3: localMin={0}, prevMin={1}, localMax={2}, prevMax={3}", 
             waitingResetLocalMin, na(prevConfirmedMin) ? 0.0 : prevConfirmedMin, waitingResetLocalMax, na(prevConfirmedMax) ? 0.0 : prevConfirmedMax)
        log.info("🔍 CHECK3: isCase1={0}, isCase2={1}, isCase3={2}, isFirst={3}, canStart={4}", isCase1 ? 1 : 0, isCase2 ? 1 : 0, isCase3 ? 1 : 0, isFirstCycle ? 1 : 0, canStartNewCycle ? 1 : 0)
        if isCase3
            log.info("🆕 CHECK3 Case3: lastCompletedMin={0}, lastCompletedMax={1}, growthFromNewMin={2}%", lastCompletedMin, lastCompletedMax, growthFromNewMin)
        
        // Проверяем что новый минимум находится после листинга
        if canStartNewCycle and not na(firstBarAfterListing) and newMinBarAbsolute >= firstBarAfterListing
            // ВАЖНО: При isCase2 используем СТАРЫЙ MIN (prevConfirmedMin), а не новый!
            // isCase1: новый MIN ниже → берём НОВЫЙ MIN
            // isCase2: новый MIN выше, но MAX ниже → продолжаем со СТАРЫМ MIN
            // isCase3: НОВЫЙ Фибо внутри завершённого диапазона → берём НОВЫЙ MIN (сброс lastCompleted)
            
            useOldMin = isCase2 and not isCase1 and not isCase3  // Case2 только если НЕ Case1 и НЕ Case3
            
            if isCase3
                log.info("🆕 NEW OPPORTUNITY (CASE3: NEW FIBO inside completed): localMin={0}, localMax={1}, growth={2}%", waitingResetLocalMin, waitingResetLocalMax, growthFromNewMin)
                // Case 3: Сбрасываем lastCompleted так как это НОВЫЙ Фибо
                lastCompletedMin := na
                lastCompletedMax := na
            else if useOldMin
                log.info("🆕 NEW OPPORTUNITY (CASE2: keep OLD MIN): localMin={0}, prevMin={1}, using prevMin, growth={2}%", waitingResetLocalMin, prevConfirmedMin, waitingResetGrowth)
            else
                log.info("🆕 NEW OPPORTUNITY (CASE1: lower MIN): localMin={0}, growth={1}%", waitingResetLocalMin, waitingResetGrowth)
            log.info("🎯 newMinBarOffset={0}, newMinBarAbsolute={1}, useOldMin={2}, isCase3={3}", newMinBarOffset, newMinBarAbsolute, useOldMin ? 1 : 0, isCase3 ? 1 : 0)
            
            // Определяем какой MIN использовать
            newMinUsesBody = false
            newMinPrice = useOldMin ? prevConfirmedMin : waitingResetLocalMin
            finalMinBar = useOldMin ? prevConfirmedMinBar : newMinBarAbsolute
            
            // ВАЖНО: СНАЧАЛА проверяем isCompletedCycle ДО любых изменений!
            // Проверяем, это тот же MIN/MAX что был полностью завершён (Этап 1 + Этап 2)
            // НО: Case 3 уже сбросил lastCompleted, поэтому эта проверка не заблокирует его
            isSameMinAsCompletedEarly = useOldMin and not na(lastCompletedMin) and math.abs(newMinPrice - lastCompletedMin) < 0.0001
            isSameMaxAsCompletedEarly = useOldMin and not na(lastCompletedMax) and not na(prevConfirmedMax) and math.abs(prevConfirmedMax - lastCompletedMax) < 0.0001
            isCompletedCycleEarly = isSameMinAsCompletedEarly and isSameMaxAsCompletedEarly
            
            if isCompletedCycleEarly
                // Этот цикл уже полностью завершён — НЕ начинаем новый цикл!
                // Остаёмся в WAITING_RESET и ждём новый MIN или MAX
                log.warning("⛔ CYCLE BLOCKED (EARLY): MIN={0}, MAX={1} already completed (lastCompletedMin={2}, lastCompletedMax={3})", 
                     newMinPrice, prevConfirmedMax, lastCompletedMin, lastCompletedMax)
                // НЕ меняем systemState — остаёмся в WAITING_RESET
                // Очищаем pendingMax чтобы он не был подтверждён
                hasPendingMax := false
                pendingMaxPrice := na
                pendingMaxBar := na
                pendingMaxUsesBody := false
                preservePendingMax := false
            else
                // Продолжаем с изменениями только если цикл НЕ завершён
                finalMinBar = useOldMin ? prevConfirmedMinBar : newMinBarAbsolute
                
                // Проверяем фитиль только если используем новый MIN (не старый)
                if not useOldMin
                    wickPctNew = getLowerWickPercent(newMinBarOffset)
                    if wickPctNew > wickThreshold
                        problemCandleBodyMin = math.min(open[newMinBarOffset], close[newMinBarOffset])
                        foundBetterMin = false
                        
                        for i = 1 to 5
                            checkIdx = newMinBarOffset + i
                            if checkIdx < waitingResetLookback
                                neighborWick = getLowerWickPercent(checkIdx)
                                if neighborWick <= wickThreshold and low[checkIdx] < problemCandleBodyMin
                                    newMinBarOffset := checkIdx
                                    newMinPrice := low[checkIdx]
                                    finalMinBar := bar_index - newMinBarOffset
                                    foundBetterMin := true
                                    break
                            checkIdxR = newMinBarOffset - i
                            if checkIdxR >= 0
                                neighborWickR = getLowerWickPercent(checkIdxR)
                                if neighborWickR <= wickThreshold and low[checkIdxR] < problemCandleBodyMin
                                    newMinBarOffset := checkIdxR
                                    newMinPrice := low[checkIdxR]
                                    finalMinBar := bar_index - newMinBarOffset
                                    foundBetterMin := true
                                    break
                        
                        if not foundBetterMin
                            newMinPrice := problemCandleBodyMin
                            newMinUsesBody := true
                
                // Начинаем новый цикл
                currentCycleId := currentCycleId + 1
                confirmedMin := newMinPrice
                confirmedMinBar := finalMinBar
                minUsesBody := useOldMin ? false : newMinUsesBody  // Старый MIN уже был проверен
                
                // ВАЖНО: Если используем старый MIN И был подтверждённый MAX в предыдущем цикле,
                // сохраняем его как PENDING MAX (нужно снова дождаться касания 0.618)
                if useOldMin and not na(prevConfirmedMax) and prevConfirmedMax > 0
                    // Сохраняем старый MAX как PENDING (не CONFIRMED!)
                    pendingMaxPrice := prevConfirmedMax
                    pendingMaxBar := prevConfirmedMaxBar
                    pendingMaxUsesBody := false  // Старый MAX уже был проверен
                    hasPendingMax := true
                    preservePendingMax := true   // ВАЖНО: Не сбрасывать в doResetOrders!
                    confirmedMax := na  // НЕ confirmed - ждём подтверждения
                    confirmedMaxBar := na
                    // Барьер для нового перехая
                    confirmedMaxRealHigh := prevConfirmedMax
                    // maxSearchStartBar сбрасываем на MIN чтобы искать перехаи от MIN
                    maxSearchStartBar := finalMinBar
                    
                    // Расчёт уровня 0.618 для подтверждения
                    expectedFib618OldMax = newMinPrice + (prevConfirmedMax - newMinPrice) * 0.618
                    log.info("════════════════════════════════════════════════════════════")
                    log.info("📊 [MAX EVENT] TYPE: KEEPING OLD MAX - NEW PENDING MAX")
                    log.info("📊 [MAX EVENT] REASON: Using old MIN, preserving prevConfirmedMax")
                    log.info("📊 [MAX EVENT] PENDING MAX: {0} at bar {1}", prevConfirmedMax, prevConfirmedMaxBar)
                    log.info("📊 [MAX EVENT] MIN: {0} at bar {1}", newMinPrice, finalMinBar)
                    log.info("📊 [MAX EVENT] Level 0.618 for confirmation: {0}", expectedFib618OldMax)
                    log.info("📊 [MAX EVENT] STATUS: Waiting for price to touch 0.618 level")
                    log.info("📊 [MAX EVENT] preservePendingMax SET to TRUE - will survive doResetOrders")
                    log.info("════════════════════════════════════════════════════════════")
                else
                    confirmedMax := na
                    confirmedMaxBar := na
                
                // ВАЖНО: При использовании старого MIN (isCase2), нужно обновить searchStartBar
                // на бар этого MIN, чтобы он не был отклонён как "невалидный" в STATE_WAITING_GROWTH
                if useOldMin
                    searchStartBar := finalMinBar  // Разрешаем использовать старый MIN
                    log.info("🔧 searchStartBar updated to finalMinBar={0} for old MIN", finalMinBar)
                // При использовании нового MIN - searchStartBar остаётся равным бару продажи
                systemState := STATE_WAITING_GROWTH
                sellCount := 0
                touchedZone06_07 := false
                position1Open := false
                position2Open := false
                position3Open := false
                doResetOrders := true
                
                // ВАЖНО: Проверяем, это тот же MIN/MAX что был при SELL на Этапе 1
                // Если да - продолжаем на Этапе 2, если нет - сброс на Этап 1
                isSameMinAsSold = useOldMin and not na(lastSoldMin) and math.abs(newMinPrice - lastSoldMin) < 0.0001
                isSameMaxAsSold = useOldMin and not na(lastSoldMax) and not na(prevConfirmedMax) and math.abs(prevConfirmedMax - lastSoldMax) < 0.0001
                
                if isSameMinAsSold and isSameMaxAsSold
                    // Тот же MIN и MAX что при SELL на Этапе 1 - продолжаем на Этапе 2
                    tradingStage := 2
                    orderLevel1 := 0.5
                    orderLevel2 := 0.382
                    orderLevel3 := 0.236
                    sellLevel1 := 0.618
                    sellLevel2 := 0.5
                    sellLevel3 := 0.382
                    cycleHadSell := false
                    // НЕ сбрасываем lastSoldMin/Max - они нужны для дальнейших проверок
                    log.info("📊 SAME MIN/MAX AS SOLD: continuing on Stage 2, cycleId={0}", currentCycleId)
                else
                    // Новый MIN или MAX - сброс на Этап 1
                    tradingStage := 1
                    orderLevel1 := 0.618
                    orderLevel2 := 0.5
                    orderLevel3 := 0.382
                    sellLevel1 := 0.786
                    sellLevel2 := 0.618
                    sellLevel3 := 0.5
                    cycleHadSell := false
                    lastSoldMin := na
                    lastSoldMax := na
                    // Новый MIN или MAX — сбрасываем завершённый Фибо
                    lastCompletedMin := na
                    lastCompletedMax := na
                    log.info("🔄 NEW CYCLE: reset to Stage 1, cycleId={0}", currentCycleId)
            
                // Удаляем старые Fibo элементы с графика (только если не сохраняем историю)
                if not showAllFiboHistory
                    box.delete(box_1_000)
                    box.delete(box_0_786)
                    box.delete(box_0_618)
                    box.delete(box_0_500)
                    box.delete(box_0_382)
                    box.delete(box_0_236)
                    label.delete(label_fib_1_000)
                    label.delete(label_fib_0_618)
                    label.delete(label_fib_0_500)
                    label.delete(label_fib_0_382)
                    label.delete(label_fib_0_236)
                    label.delete(label_min)
                    label.delete(label_max)
            
                box_1_000 := na
                box_0_786 := na
                box_0_618 := na
                box_0_500 := na
                box_0_382 := na
                box_0_236 := na
                label_fib_1_000 := na
                label_fib_0_618 := na
                label_fib_0_500 := na
                label_fib_0_382 := na
                label_fib_0_236 := na
                label_min := na
                label_max := na
                fiboWasDrawn := false
                drawnCycleId := -1
                drawnMaxBar := na
                prevConfirmedMax := na
                prevConfirmedMin := na
                prevConfirmedMaxBar := na
                prevConfirmedMinBar := na
            
                log.info("🎯 NEW CYCLE FROM WAITING_RESET: min={0}, minBar={1}, usesBody={2}, searchStartBar={3}, hasPendingMax={4}, pendingMax={5}", 
                     confirmedMin, confirmedMinBar, minUsesBody, na(searchStartBar) ? -1 : searchStartBar, hasPendingMax, hasPendingMax ? pendingMaxPrice : 0.0)

// ============================================================================
// ОТРИСОВКА УРОВНЕЙ FIBONACCI
// ============================================================================

var label label_waiting_min = na

var int prevSystemState = na

// Метка MIN в режиме ожидания роста
if showLabels and systemState == STATE_WAITING_GROWTH and not na(confirmedMin) and not na(confirmedMinBar)
    label.delete(label_waiting_min)
    waitingGrowth = ((high - confirmedMin) / confirmedMin) * 100
    label_waiting_min := label.new(confirmedMinBar, confirmedMin, 
         "MIN\n" + str.tostring(confirmedMin, "#.####") + (minUsesBody ? "\n(body)" : "") + "\n⏳ " + str.tostring(waitingGrowth, "#.#") + "%", 
         color=color.new(color.orange, 0), textcolor=color.white, style=label.style_label_up, size=size.small)
else if systemState != STATE_WAITING_GROWTH and not na(label_waiting_min)
    label.delete(label_waiting_min)
    label_waiting_min := na

deleteFiboBoxes() =>
    box.delete(box_1_000)
    box.delete(box_0_786)
    box.delete(box_0_618)
    box.delete(box_0_500)
    box.delete(box_0_382)
    box.delete(box_0_236)
    label.delete(label_min)
    label.delete(label_max)
    label.delete(label_fib_1_000)
    label.delete(label_fib_0_618)
    label.delete(label_fib_0_500)
    label.delete(label_fib_0_382)
    label.delete(label_fib_0_236)

cycleChanged = false

if systemState == STATE_WAITING_RESET and prevSystemState == STATE_FIBO_ACTIVE
    // НЕ удаляем боксы - они остаются на графике как история
    // Просто сбрасываем переменные чтобы новый цикл создал новые боксы
    box_1_000 := na
    box_0_786 := na
    box_0_618 := na
    box_0_500 := na
    box_0_382 := na
    box_0_236 := na
    label_fib_1_000 := na
    label_fib_0_618 := na
    label_fib_0_500 := na
    label_fib_0_382 := na
    label_fib_0_236 := na
    label_min := na
    label_max := na
    // Удаляем линии локальных MAX при переходе в WAITING_RESET
    deleteLocalMaxLines()
    fiboWasDrawn := false
    drawnCycleId := -1
    log.info("📦 WAITING_RESET: Fibo variables reset (boxes remain on chart)")

if systemState == STATE_SEARCHING_MIN and prevSystemState != STATE_SEARCHING_MIN
    cycleChanged := true
    // НЕ удаляем боксы - они остаются на графике как история
    box_1_000 := na
    box_0_786 := na
    box_0_618 := na
    box_0_500 := na
    box_0_382 := na
    box_0_236 := na
    label_min := na
    label_max := na
    label_fib_1_000 := na
    label_fib_0_618 := na
    label_fib_0_500 := na
    label_fib_0_382 := na
    label_fib_0_236 := na
    fiboWasDrawn := false
    drawnCycleId := -1
    drawnMaxBar := na

// ВАЖНО: Сравниваем effectiveMax (который включает pendingMaxPrice), не confirmedMax!
needsRedraw = canBuildFibo and (forceRedraw or drawnCycleId != currentCycleId or effectiveMax != drawnMax or confirmedMin != drawnMin or effectiveMaxBar != drawnMaxBar)

// Дебаг рисования Фибо
if barstate.isconfirmed and systemState == STATE_FIBO_ACTIVE
    log.info("🎨 DRAW CHECK bar={0}: showFibLines={1}, canBuild={2}, needsRedraw={3}, drawnCycleId={4}, currentCycleId={5}", 
         bar_index, showFibLines, canBuildFibo, needsRedraw, drawnCycleId, currentCycleId)

if showFibLines and canBuildFibo
    if needsRedraw
        // Удаляем старые элементы ТОЛЬКО если это обновление того же цикла
        // Для нового цикла - просто создаём новые (старые остаются как история)
        if drawnCycleId == currentCycleId or not showAllFiboHistory
            box.delete(box_1_000)
            box.delete(box_0_786)
            box.delete(box_0_618)
            box.delete(box_0_500)
            box.delete(box_0_382)
            box.delete(box_0_236)
            label.delete(label_fib_1_000)
            label.delete(label_fib_0_618)
            label.delete(label_fib_0_500)
            label.delete(label_fib_0_382)
            label.delete(label_fib_0_236)
            label.delete(label_min)
            label.delete(label_max)
        
        box_1_000 := na
        box_0_786 := na
        box_0_618 := na
        box_0_500 := na
        box_0_382 := na
        box_0_236 := na
        label_fib_1_000 := na
        label_fib_0_618 := na
        label_fib_0_500 := na
        label_fib_0_382 := na
        label_fib_0_236 := na
        label_min := na
        label_max := na
        
        // ВАЖНО: Используем effectiveMaxBar (который может быть pendingMaxBar)
        startBar = effectiveMaxBar
        endBar = bar_index
        
        isStartBarValid = not na(startBar) and startBar >= 0 and startBar <= bar_index
        
        log.info("📦 BOX CREATE: startBar={0}, endBar={1}, cycle={2}, minBar={3}, valid={4}", 
             na(startBar) ? -1 : startBar, endBar, currentCycleId, 
             na(confirmedMinBar) ? -1 : confirmedMinBar, isStartBarValid ? 1 : 0)
        
        if not isStartBarValid
            log.warning("⚠️ INVALID startBar! startBar={0}, confirmedMinBar={1}, bar_index={2} - SKIPPING BOX CREATE", 
                 na(startBar) ? -999 : startBar, na(confirmedMinBar) ? -999 : confirmedMinBar, bar_index)
        else
            // Создаём боксы ТОЛЬКО когда данные валидны
            boxHeight = fibRange * 0.001
            log.info("✅ BOXES CREATED: bar={0}, fib_1={1}, fib_0={2}", bar_index, fib_1_000, fib_0_000)
            
            alphaMain = 30
            alphaSecondary = 50
            
            // Минималистичный режим: показываем только уровни с открытыми позициями
            // MAX (100%) - всегда показываем как ориентир
            box_1_000 := box.new(startBar, fib_1_000 + boxHeight/4, endBar, fib_1_000 - boxHeight/4, 
                 border_color=color.new(color.blue, alphaSecondary), bgcolor=color.new(color.blue, 70), border_width=1)
            
            // 78.6% - уровень SELL (ВСЕГДА показываем как ориентир для продажи)
            box_0_786 := box.new(startBar, fib_0_786 + boxHeight/2, endBar, fib_0_786 - boxHeight/2, 
                 border_color=color.new(color.purple, 30), bgcolor=color.new(color.purple, 60), border_width=1)
            
            // Уровни BUY - показываем только если позиция открыта
            if position1Open
                box_0_618 := box.new(startBar, fib_0_618 + boxHeight, endBar, fib_0_618 - boxHeight, 
                     border_color=color.new(color.lime, 20), bgcolor=color.new(color.lime, 40), border_width=2)
            if position2Open
                box_0_500 := box.new(startBar, fib_0_500 + boxHeight, endBar, fib_0_500 - boxHeight, 
                     border_color=color.new(color.lime, 20), bgcolor=color.new(color.lime, 40), border_width=2)
            if position3Open
                box_0_382 := box.new(startBar, fib_0_382 + boxHeight, endBar, fib_0_382 - boxHeight, 
                     border_color=color.new(color.lime, 20), bgcolor=color.new(color.lime, 40), border_width=2)
            
            // MIN (0%) - показываем как STOP-LOSS уровень если есть открытые позиции
            if position1Open or position2Open or position3Open
                box_0_236 := box.new(startBar, fib_0_000 + boxHeight/4, endBar, fib_0_000 - boxHeight/4, 
                     border_color=color.new(color.red, 30), bgcolor=color.new(color.red, 60), border_width=1)
            
            // Формируем общую информацию о торговле для tooltip
            tooltipMin = nz(confirmedMin, fib_0_000)
            tooltipMax = nz(confirmedMax, fib_1_000)
            tooltipMinBar = nz(confirmedMinBar, 0)
            tooltipMaxBar = nz(confirmedMaxBar, 0)
            growthPct = tooltipMin > 0 ? ((tooltipMax - tooltipMin) / tooltipMin) * 100 : 0
            // Проверяем что рост >= 100% перед отображением MAX
            growthIsEnough = growthPct >= minGrowthPercent
            tradeInfo = "═══ FIBONACCI INFO ═══" +
                 "\nMIN: " + str.tostring(tooltipMin, "#.####") + " (бар " + str.tostring(tooltipMinBar) + ")" +
                 "\nMAX: " + str.tostring(tooltipMax, "#.####") + " (бар " + str.tostring(tooltipMaxBar) + ")" +
                 "\nРост: " + str.tostring(growthPct, "#.#") + "%" +
                 "\n═══ ОРДЕРА BUY ═══" +
                 "\n• 61.8%: $" + str.tostring(orderAmount1, "#") + " @ " + str.tostring(nz(order1Price, 0), "#.####") + (position1Open ? " ✓ОТКРЫТ" : (position1WasBought ? " ✓ПРОДАН" : "")) +
                 "\n• 50%: $" + str.tostring(orderAmount2, "#") + " @ " + str.tostring(nz(order2Price, 0), "#.####") + (position2Open ? " ✓ОТКРЫТ" : (position2WasBought ? " ✓ПРОДАН" : "")) +
                 "\n• 38.2%: $" + str.tostring(orderAmount3, "#") + " @ " + str.tostring(nz(order3Price, 0), "#.####") + (position3Open ? " ✓ОТКРЫТ" : (position3WasBought ? " ✓ПРОДАН" : "")) +
                 "\n═══ ОРДЕРА SELL ═══" +
                 "\n• 78.6%: @ " + str.tostring(nz(sell1Price, 0), "#.####") +
                 "\n• 61.8%: @ " + str.tostring(nz(sell2Price, 0), "#.####") +
                 "\n• 50%: @ " + str.tostring(nz(sell3Price, 0), "#.####")
            
            if showFibLevels
                // MAX уровень - всегда показываем
                label_fib_1_000 := label.new(endBar, fib_1_000, "100% (" + str.tostring(fib_1_000, "#.####") + ")", 
                     color=color.new(color.blue, 80), textcolor=color.blue, style=label.style_label_left, size=size.small,
                     tooltip=tradeInfo)
                // Уровни BUY - показываем только если позиция открыта
                if position1Open
                    label_fib_0_618 := label.new(endBar, fib_0_618, "61.8% BUY ✓", 
                         color=color.new(color.lime, 50), textcolor=color.lime, style=label.style_label_left, size=size.small,
                         tooltip=tradeInfo + "\n\n✓ BUY $" + str.tostring(orderAmount1, "#") + " @ " + str.tostring(nz(entryPrice1, order1Price), "#.####"))
                if position2Open
                    label_fib_0_500 := label.new(endBar, fib_0_500, "50% BUY ✓", 
                         color=color.new(color.lime, 50), textcolor=color.lime, style=label.style_label_left, size=size.small,
                         tooltip=tradeInfo + "\n\n✓ BUY $" + str.tostring(orderAmount2, "#") + " @ " + str.tostring(nz(entryPrice2, order2Price), "#.####"))
                if position3Open
                    label_fib_0_382 := label.new(endBar, fib_0_382, "38.2% BUY ✓", 
                         color=color.new(color.lime, 50), textcolor=color.lime, style=label.style_label_left, size=size.small,
                         tooltip=tradeInfo + "\n\n✓ BUY $" + str.tostring(orderAmount3, "#") + " @ " + str.tostring(nz(entryPrice3, order3Price), "#.####"))
                // MIN (STOP-LOSS) - показываем если есть открытые позиции
                if position1Open or position2Open or position3Open
                    label_fib_0_236 := label.new(endBar, fib_0_000, "0% STOP", 
                         color=color.new(color.red, 50), textcolor=color.red, style=label.style_label_left, size=size.small,
                         tooltip="STOP-LOSS @ " + str.tostring(fib_0_000, "#.####"))
            
            // MIN и MAX метки - всегда показываем когда Фибо активен
            label_min := label.new(confirmedMinBar, na, "MIN\n" + str.tostring(tooltipMin, "#.####") + (minUsesBody ? "\n(body)" : ""), 
                 color=color.new(color.red, 0), textcolor=color.white, style=label.style_label_up, size=size.small,
                 yloc=yloc.belowbar,
                 tooltip="STOP-LOSS: " + str.tostring(tooltipMin, "#.####") + "\nБар: " + str.tostring(tooltipMinBar))
            // MAX label показываем только если:
            // 1. Была покупка (cycleHadBuy)
            // 2. Рост >= 100% (growthIsEnough)
            // 3. Нет pending MAX (MAX подтверждён) ИЛИ есть подтверждённый confirmedMax
            hasConfirmedMax = not na(confirmedMax) and confirmedMax > 0
            if cycleHadBuy and growthIsEnough and hasConfirmedMax
                label_max := label.new(confirmedMaxBar, na, "MAX\n" + str.tostring(confirmedMax, "#.####") + (maxUsesBody ? "\n(body)" : ""), 
                     color=color.new(color.blue, 0), textcolor=color.white, style=label.style_label_down, size=size.small,
                     yloc=yloc.abovebar,
                     tooltip="MAX: " + str.tostring(confirmedMax, "#.####") + "\nСвязанный MIN: " + str.tostring(tooltipMin, "#.####") + " (бар " + str.tostring(tooltipMinBar) + ")\nРост: " + str.tostring(growthPct, "#.#") + "%")
            
            drawnCycleId := currentCycleId
            drawnMax := effectiveMax  // Сохраняем effectiveMax (включает pendingMaxPrice)
            drawnMin := confirmedMin
            drawnMaxBar := effectiveMaxBar  // И effectiveMaxBar
            fiboWasDrawn := true
            forceRedraw := false  // Сбрасываем флаг принудительной перерисовки
    
    else if not na(box_1_000)
        // Продлеваем боксы до текущего бара
        box.set_right(box_1_000, bar_index)
        
        // Продлеваем только боксы открытых позиций
        if not na(box_0_618)
            box.set_right(box_0_618, bar_index)
        if not na(box_0_500)
            box.set_right(box_0_500, bar_index)
        if not na(box_0_382)
            box.set_right(box_0_382, bar_index)
        if not na(box_0_236)
            box.set_right(box_0_236, bar_index)
            
        if showFibLevels and not na(label_fib_1_000)
            label.set_x(label_fib_1_000, bar_index)
            if not na(label_fib_0_618)
                label.set_x(label_fib_0_618, bar_index)
            if not na(label_fib_0_500)
                label.set_x(label_fib_0_500, bar_index)
            if not na(label_fib_0_382)
                label.set_x(label_fib_0_382, bar_index)
            if not na(label_fib_0_236)
                label.set_x(label_fib_0_236, bar_index)

// Отрисовка pending MAX (пунктирная линия)
if hasPendingMax and showFibLines and showPendingMax
    // Удаляем старые линии
    line.delete(line_pending_max)
    label.delete(label_pending_max)
    line.delete(line_pending_fib618)
    
    // Рисуем новый pending MAX
    pending_fib_0618_draw = getFibLevel(0.382, confirmedMin, pendingMaxPrice, useLogScale)
    line_pending_max := line.new(pendingMaxBar, pendingMaxPrice, bar_index, pendingMaxPrice, 
         color=color.new(color.purple, 30), width=2, style=line.style_dashed)
    label_pending_max := label.new(bar_index, pendingMaxPrice, "⏳ PENDING MAX\n" + str.tostring(pendingMaxPrice, "#.####"), 
         color=color.new(color.purple, 50), textcolor=color.white, style=label.style_label_left, size=size.small,
         tooltip="Ожидает подтверждения касанием 0.618 @ " + str.tostring(pending_fib_0618_draw, "#.####"))
    // Линия уровня 0.618 для подтверждения
    line_pending_fib618 := line.new(pendingMaxBar, pending_fib_0618_draw, bar_index, pending_fib_0618_draw, 
         color=color.new(color.orange, 50), width=1, style=line.style_dotted)
else if not hasPendingMax or not showPendingMax
    // Удаляем линии если нет pending MAX
    line.delete(line_pending_max)
    label.delete(label_pending_max)
    line.delete(line_pending_fib618)
    line_pending_max := na
    label_pending_max := na
    line_pending_fib618 := na

// ============================================================================
// ОТРИСОВКА ЛОКАЛЬНЫХ MAX
// ============================================================================

if showLocalMax and showFibLines and systemState == STATE_FIBO_ACTIVE and not na(confirmedMin)
    // Удаляем старые линии локальных MAX
    for i = 0 to 4
        existingLine = array.get(localMaxLines, i)
        existing618Line = array.get(localMax618Lines, i)
        existingLabel = array.get(localMaxLabels, i)
        if not na(existingLine)
            line.delete(existingLine)
        if not na(existing618Line)
            line.delete(existing618Line)
        if not na(existingLabel)
            label.delete(existingLabel)
        array.set(localMaxLines, i, na)
        array.set(localMax618Lines, i, na)
        array.set(localMaxLabels, i, na)
    
    // Рисуем новые линии локальных MAX
    for i = 0 to 4
        localPrice = array.get(localMaxPrices, i)
        localBar = array.get(localMaxBars, i)
        
        if not na(localPrice) and not na(localBar) and localPrice > 0 and localBar > 0
            // Линия локального MAX (серая пунктирная)
            maxLine = line.new(localBar, localPrice, bar_index, localPrice, 
                 color=color.new(color.gray, 50), width=1, style=line.style_dotted)
            array.set(localMaxLines, i, maxLine)
            
            // Уровень 0.618 от локального MAX (оранжевая пунктирная)
            local_fib_0618 = getFibLevel(0.382, confirmedMin, localPrice, useLogScale)
            fib618Line = line.new(localBar, local_fib_0618, bar_index, local_fib_0618, 
                 color=color.new(color.orange, 70), width=1, style=line.style_dotted)
            array.set(localMax618Lines, i, fib618Line)
            
            // Метка с ценой
            localLabel = label.new(localBar, localPrice, "L" + str.tostring(i + 1) + "\n" + str.tostring(localPrice, "#.####"), 
                 color=color.new(color.gray, 70), textcolor=color.white, style=label.style_label_down, size=size.tiny,
                 tooltip="Локальный MAX #" + str.tostring(i + 1) + "\nЦена: " + str.tostring(localPrice, "#.####") + "\n0.618: " + str.tostring(local_fib_0618, "#.####"))
            array.set(localMaxLabels, i, localLabel)

// ============================================================================
// ТАБЛИЦА СТАТИСТИКИ
// ============================================================================

var table infoTable = table.new(position.top_right, 2, 16, 
     bgcolor=color.new(color.gray, 85), 
     frame_color=color.new(color.gray, 50), 
     frame_width=1)

if showInfo and barstate.islast
    // Расчет периода торговли
    tradingDays = na(firstTradeTime) ? 0 : math.floor((time - firstTradeTime) / (24 * 60 * 60 * 1000)) + 1
    tradingYears = tradingDays > 0 ? tradingDays / 365.0 : 0.0
    
    // % годовых (Annual Return) = (прибыль / начальный капитал) * (365 / дней) * 100
    initialCapital = 500.0  // Должен соответствовать initial_capital в strategy()
    annualReturn = tradingDays > 0 ? (totalProfitLoss / initialCapital) * (365.0 / tradingDays) * 100 : 0.0
    
    // Период в текстовом формате
    periodText = tradingDays == 0 ? "—" : (tradingDays < 30 ? str.tostring(tradingDays) + " дн." : (tradingDays < 365 ? str.tostring(math.floor(tradingDays / 30)) + " мес. " + str.tostring(tradingDays % 30) + " дн." : str.tostring(math.floor(tradingDays / 365)) + " г. " + str.tostring(math.floor((tradingDays % 365) / 30)) + " мес."))
    
    // ===== РАСЧЕТ НЕРЕАЛИЗОВАННОГО P&L =====
    unrealizedPL1 = position1Open and not na(entryPrice1) and entryPrice1 > 0 ? ((close - entryPrice1) / entryPrice1) * orderAmount1 : 0.0
    unrealizedPL2 = position2Open and not na(entryPrice2) and entryPrice2 > 0 ? ((close - entryPrice2) / entryPrice2) * orderAmount2 : 0.0
    unrealizedPL3 = position3Open and not na(entryPrice3) and entryPrice3 > 0 ? ((close - entryPrice3) / entryPrice3) * orderAmount3 : 0.0
    totalUnrealizedPL = unrealizedPL1 + unrealizedPL2 + unrealizedPL3
    
    // Количество открытых позиций
    openPositionsCountTable = (position1Open ? 1 : 0) + (position2Open ? 1 : 0) + (position3Open ? 1 : 0)
    
    // Общий P&L (реализованный + нереализованный)
    totalPL = totalProfitLoss + totalUnrealizedPL
    
    // ===== СТАТИСТИКА =====
    table.cell(infoTable, 0, 0, "📊 СТАТИСТИКА", text_size=size.small, bgcolor=color.new(color.purple, 70), text_color=color.white)
    table.cell(infoTable, 1, 0, "━━━━━━━━", text_size=size.small, bgcolor=color.new(color.purple, 70), text_color=color.white)
    
    // Период торговли
    table.cell(infoTable, 0, 1, "📅 Период", text_size=size.small, text_color=color.aqua)
    table.cell(infoTable, 1, 1, periodText, text_size=size.small, text_color=color.aqua)
    
    // Реализованный P&L
    plColor = totalProfitLoss >= 0 ? color.green : color.red
    plSign = totalProfitLoss >= 0 ? "+" : ""
    table.cell(infoTable, 0, 2, "💰 Реализ. P&L", text_size=size.small, text_color=plColor)
    table.cell(infoTable, 1, 2, plSign + str.tostring(totalProfitLoss, "#.##") + " USDT", text_size=size.small, text_color=plColor)
    
    // Нереализованный P&L (открытые позиции)
    uplColor = totalUnrealizedPL >= 0 ? color.lime : color.orange
    uplSign = totalUnrealizedPL >= 0 ? "+" : ""
    uplText = openPositionsCountTable > 0 ? uplSign + str.tostring(totalUnrealizedPL, "#.##") + " (" + str.tostring(openPositionsCountTable) + " поз.)" : "— (нет)"
    table.cell(infoTable, 0, 3, "📦 Нереализ. P&L", text_size=size.small, text_color=uplColor)
    table.cell(infoTable, 1, 3, uplText, text_size=size.small, text_color=uplColor)
    
    // Общий P&L
    totalPLColor = totalPL >= 0 ? color.green : color.red
    totalPLSign = totalPL >= 0 ? "+" : ""
    table.cell(infoTable, 0, 4, "💵 Общий P&L", text_size=size.small, text_color=totalPLColor, bgcolor=color.new(totalPLColor, 85))
    table.cell(infoTable, 1, 4, totalPLSign + str.tostring(totalPL, "#.##") + " USDT", text_size=size.small, text_color=totalPLColor, bgcolor=color.new(totalPLColor, 85))
    
    // % годовых
    arColor = annualReturn >= 0 ? color.green : color.red
    arSign = annualReturn >= 0 ? "+" : ""
    table.cell(infoTable, 0, 5, "📈 % годовых", text_size=size.small, text_color=arColor)
    table.cell(infoTable, 1, 5, arSign + str.tostring(annualReturn, "#.#") + "%", text_size=size.small, text_color=arColor)
    
    // Максимальная просадка
    table.cell(infoTable, 0, 6, "📉 Макс. просадка", text_size=size.small, text_color=color.red)
    table.cell(infoTable, 1, 6, "-" + str.tostring(maxDrawdown, "#.##") + " USDT", text_size=size.small, text_color=color.red)
    
    // Всего сделок
    table.cell(infoTable, 0, 7, "📊 Всего сделок", text_size=size.small, text_color=color.white)
    table.cell(infoTable, 1, 7, str.tostring(totalTrades), text_size=size.small, text_color=color.white)
    
    // Win Rate (% прибыльных)
    winRate = totalTrades > 0 ? (profitableTrades / totalTrades) * 100 : 0.0
    winRateColor = winRate >= 50 ? color.green : color.orange
    table.cell(infoTable, 0, 8, "🎯 Win Rate", text_size=size.small, text_color=winRateColor)
    table.cell(infoTable, 1, 8, str.tostring(winRate, "#.#") + "% (" + str.tostring(profitableTrades) + "/" + str.tostring(totalTrades) + ")", text_size=size.small, text_color=winRateColor)
    
    // Profit Factor
    profitFactor = grossLoss > 0 ? grossProfit / grossLoss : (grossProfit > 0 ? 999.99 : 0.0)
    pfColor = profitFactor >= 1.5 ? color.green : (profitFactor >= 1.0 ? color.orange : color.red)
    table.cell(infoTable, 0, 9, "⚖️ Profit Factor", text_size=size.small, text_color=pfColor)
    table.cell(infoTable, 1, 9, str.tostring(profitFactor, "#.##"), text_size=size.small, text_color=pfColor)
    
    // Gross Profit / Gross Loss
    table.cell(infoTable, 0, 10, "✅ Gross Profit", text_size=size.small, text_color=color.green)
    table.cell(infoTable, 1, 10, "+" + str.tostring(grossProfit, "#.##") + " USDT", text_size=size.small, text_color=color.green)
    
    table.cell(infoTable, 0, 11, "❌ Gross Loss", text_size=size.small, text_color=color.red)
    table.cell(infoTable, 1, 11, "-" + str.tostring(grossLoss, "#.##") + " USDT", text_size=size.small, text_color=color.red)
    
    // Разделитель для открытых позиций
    table.cell(infoTable, 0, 12, "━━ ПОЗИЦИИ ━━", text_size=size.tiny, bgcolor=color.new(color.blue, 70), text_color=color.white)
    table.cell(infoTable, 1, 12, "━━━━━━━━", text_size=size.tiny, bgcolor=color.new(color.blue, 70), text_color=color.white)
    
    // Текущий этап торговли
    stageColor = tradingStage == 1 ? color.aqua : color.yellow
    stageTextTable = tradingStage == 1 ? "Этап 1 (0.618/0.5/0.382)" : "Этап 2 (0.5/0.382/0.236)"
    table.cell(infoTable, 0, 13, "🔄 Этап", text_size=size.tiny, text_color=stageColor)
    table.cell(infoTable, 1, 13, stageTextTable, text_size=size.tiny, text_color=stageColor)
    
    // Детали открытых позиций
    pos1Text = position1Open ? "BUY1: " + (unrealizedPL1 >= 0 ? "+" : "") + str.tostring(unrealizedPL1, "#.##") : "—"
    pos2Text = position2Open ? "BUY2: " + (unrealizedPL2 >= 0 ? "+" : "") + str.tostring(unrealizedPL2, "#.##") : "—"
    pos3Text = position3Open ? "BUY3: " + (unrealizedPL3 >= 0 ? "+" : "") + str.tostring(unrealizedPL3, "#.##") : "—"
    pos1Color = position1Open ? (unrealizedPL1 >= 0 ? color.lime : color.orange) : color.gray
    pos2Color = position2Open ? (unrealizedPL2 >= 0 ? color.lime : color.orange) : color.gray
    pos3Color = position3Open ? (unrealizedPL3 >= 0 ? color.lime : color.orange) : color.gray
    
    table.cell(infoTable, 0, 14, pos1Text, text_size=size.tiny, text_color=pos1Color)
    table.cell(infoTable, 1, 14, pos2Text + " | " + pos3Text, text_size=size.tiny, text_color=position2Open or position3Open ? color.white : color.gray)

// ============================================================================
// АЛЕРТЫ
// ============================================================================

alertcondition(systemState[1] == STATE_SEARCHING_MIN and systemState == STATE_WAITING_GROWTH, 
     title="New Low найден", message="📍 Новый минимум найден, ждём +100%")

alertcondition(systemState[1] == STATE_WAITING_GROWTH and systemState == STATE_FIBO_ACTIVE, 
     title="Импульс +100%", message="✅ Импульс +100% выполнен! Фибо построено")

alertcondition(canBuildFibo and confirmedMax > confirmedMax[1] and not touchedZone06_07, 
     title="Перехай", message="📈 Перехай! Фибо обновлено")

alertcondition(touchOrder1 and not position1Open[1] and systemState == STATE_FIBO_ACTIVE, 
     title="BUY на уровне 1", message="🟢 BUY $100 сработал")
alertcondition(touchOrder2 and not position2Open[1] and systemState == STATE_FIBO_ACTIVE, 
     title="BUY на уровне 2", message="🟢 BUY $150 сработал")
alertcondition(touchOrder3 and not position3Open[1] and systemState == STATE_FIBO_ACTIVE, 
     title="BUY на уровне 3", message="🟢 BUY $250 сработал")

alertcondition(touchSell1 and position1Open[1] and sellCount[1] == 0, 
     title="SELL #1", message="🔴 SELL #1 выполнен! Переход на Этап 2")
alertcondition(touchSell1 and position1Open[1] and sellCount[1] >= 1, 
     title="SELL #2", message="🔴 SELL #2 выполнен! Торговля остановлена")
alertcondition(touchSell2 and position2Open[1], 
     title="SELL позиции 2", message="🔴 SELL $150 сработал")
alertcondition(touchSell3 and position3Open[1] and not position2Open[1], 
     title="SELL позиции 3", message="🔴 SELL $250 сработал")

alertcondition(enableStopLoss and touchLevel0 and (position1Open[1] or position2Open[1] or position3Open[1]), 
     title="STOP-LOSS", message="⛔ STOP-LOSS на уровне 0!")

alertcondition(systemState == STATE_WAITING_RESET and systemState[1] == STATE_FIBO_ACTIVE, 
     title="Цикл завершён", message="✅ SELL выполнен. Ждём новый цикл")

alertcondition(systemState == STATE_SEARCHING_MIN and systemState[1] == STATE_WAITING_RESET, 
     title="Новый лой → Reset", message="📉 Новый лой! Ждём снова +100%")

// ============================================================================
// DEBUG
// ============================================================================

// Визуальная отладка на последнем баре
var label debugLabel = na
if barstate.islast
    label.delete(debugLabel)
    stateNames = switch systemState
        STATE_SEARCHING_MIN => "SEARCHING_MIN"
        STATE_WAITING_GROWTH => "WAITING_GROWTH"
        STATE_FIBO_ACTIVE => "FIBO_ACTIVE"
        STATE_WAITING_RESET => "WAITING_RESET"
        => "UNKNOWN"
    
    // Дополнительная отладка для WAITING_RESET
    debugText = "DEBUG:\nState: " + stateNames + 
         "\nsearchStartBar: " + (na(searchStartBar) ? "na" : str.tostring(searchStartBar)) +
         "\nbar_index: " + str.tostring(bar_index) +
         "\nlookback: " + str.tostring(waitingResetLookback) +
         "\nlocalMin: " + str.tostring(waitingResetLocalMin, "#.####") +
         "\nlocalMinBar: " + str.tostring(waitingResetLocalMinBar) +
         "\ngrowth: " + str.tostring(waitingResetGrowth, "#.#") + "%" +
         "\nconfirmedMin: " + (na(confirmedMin) ? "na" : str.tostring(confirmedMin, "#.####")) +
         "\nconfirmedMax: " + (na(confirmedMax) ? "na" : str.tostring(confirmedMax, "#.####"))
    
    if systemState == STATE_WAITING_RESET
        cond1 = low < confirmedMin * 0.98
        cond2 = high > confirmedMax
        cond3_growth = waitingResetGrowth >= 100
        cond3_notna = not na(waitingResetLocalMin)
        cond3_above = na(confirmedMin) ? false : waitingResetLocalMin > confirmedMin * 0.98
        debugText := debugText + 
             "\n--- CHECKS ---" +
             "\nCheck1 (low<min*0.98): " + (cond1 ? "YES" : "no") +
             "\nCheck2 (high>max): " + (cond2 ? "YES" : "no") +
             "\nCheck3 growth>=100: " + (cond3_growth ? "YES" : "no") +
             "\nCheck3 notNa: " + (cond3_notna ? "YES" : "no") +
             "\nCheck3 above*0.98: " + (cond3_above ? "YES" : "no") +
             "\nmin*0.98=" + (na(confirmedMin) ? "na" : str.tostring(confirmedMin * 0.98, "#.####"))
    
    debugLabel := label.new(bar_index + 5, high, debugText, 
         color=color.new(color.black, 20), textcolor=color.white, 
         style=label.style_label_left, size=size.normal, textalign=text.align_left)
    
    log.info("📊 LAST BAR: state={0}, min={1}, minBar={2}, max={3}, maxBar={4}, canFibo={5}", 
         stateNames, 
         na(confirmedMin) ? 0.0 : confirmedMin, 
         na(confirmedMinBar) ? -1 : confirmedMinBar,
         na(confirmedMax) ? 0.0 : confirmedMax,
         na(confirmedMaxBar) ? -1 : confirmedMaxBar,
         canBuildFibo ? 1 : 0)

// ============================================================================
// PLOTS
// ============================================================================

plot(confirmedMin, "Минимум", color=color.new(color.green, 100), display=display.data_window)
plot(confirmedMax, "Максимум", color=color.new(color.red, 100), display=display.data_window)
plot(canBuildFibo ? 1 : 0, "Фибо активно", color=color.new(color.blue, 100), display=display.data_window)
plotchar(systemState, "Состояние", "", location=location.top)
